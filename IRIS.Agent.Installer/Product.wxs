<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="IRIS Agent"
           Manufacturer="University of San Carlos - SAFAD ACC"
           Version="$(var.ProductVersion)"
           UpgradeCode="7EF884DD-F012-4A22-B7B6-1B967D17E548"
           Language="1033"
           Scope="perMachine"
           InstallerVersion="500"
           Compressed="yes">

    <SummaryInformation Description="IRIS endpoint agent" Manufacturer="University of San Carlos - SAFAD ACC" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="ARPNOREPAIR" Value="1" />
    <Property Id="ENABLE_CUSTOM_BOOTSTRAP" Value="1" />

    <Launch Condition="Privileged"
            Message="Administrator privileges are required to install IRIS Agent. Run the installer from an elevated Command Prompt or PowerShell window." />

    <Feature Id="MainFeature" Title="IRIS Agent" Level="1">
      <ComponentGroupRef Id="AgentFiles" />
      <ComponentRef Id="AgentTaskScriptComponent" />
      <ComponentRef Id="PipeTokenScriptComponent" />
      <ComponentRef Id="StartMenuShortcutComponent" />
    </Feature>

    <CustomAction Id="DeleteAgentTask"
                  Directory="SystemFolder"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  ExeCommand='schtasks.exe /Delete /TN "IRISAgent" /F' />

    <CustomAction Id="DeleteAgentHelperTask"
                  Directory="SystemFolder"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  ExeCommand='schtasks.exe /Delete /TN "IRISAgentHelper" /F' />

    <CustomAction Id="DeleteAgentWakeTask"
                  Directory="SystemFolder"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  ExeCommand='schtasks.exe /Delete /TN "IRISAgentWakeCheck" /F' />

    <CustomAction Id="RemoveSnapshotUrlAcl"
            Directory="SystemFolder"
            Execute="deferred"
            Impersonate="no"
            Return="ignore"
            ExeCommand='netsh.exe http delete urlacl url=http://+:5057/' />

    <CustomAction Id="RemoveFileApiUrlAcl"
            Directory="SystemFolder"
            Execute="deferred"
            Impersonate="no"
            Return="ignore"
            ExeCommand='netsh.exe http delete urlacl url=http://+:5065/' />

    <CustomAction Id="RemoveSnapshotFirewallRule"
            Directory="SystemFolder"
            Execute="deferred"
            Impersonate="no"
            Return="ignore"
            ExeCommand='netsh.exe advfirewall firewall delete rule name="IRIS Agent Snapshot TCP 5057"' />

    <CustomAction Id="RemoveFileApiFirewallRule"
            Directory="SystemFolder"
            Execute="deferred"
            Impersonate="no"
            Return="ignore"
            ExeCommand='netsh.exe advfirewall firewall delete rule name="IRIS Agent File API TCP 5065"' />

    <CustomAction Id="DeleteAgentTaskBeforeInstall"
                  Directory="SystemFolder"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  ExeCommand='schtasks.exe /Delete /TN "IRISAgent" /F' />

    <CustomAction Id="DeleteAgentHelperTaskBeforeInstall"
                  Directory="SystemFolder"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  ExeCommand='schtasks.exe /Delete /TN "IRISAgentHelper" /F' />

    <CustomAction Id="DeleteAgentWakeTaskBeforeInstall"
                  Directory="SystemFolder"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  ExeCommand='schtasks.exe /Delete /TN "IRISAgentWakeCheck" /F' />

    <CustomAction Id="StopLegacyAgentServiceBeforeInstall"
            Directory="SystemFolder"
            Execute="deferred"
                  Impersonate="no"
            Return="ignore"
            ExeCommand='sc.exe stop "IRISAgent"' />

    <CustomAction Id="DeleteLegacyAgentServiceBeforeInstall"
            Directory="SystemFolder"
            Execute="deferred"
                  Impersonate="no"
            Return="ignore"
            ExeCommand='sc.exe delete "IRISAgent"' />

        <CustomAction Id="AddSnapshotUrlAclBeforeInstall"
          Directory="SystemFolder"
          Execute="deferred"
          Impersonate="no"
          Return="ignore"
          ExeCommand='netsh.exe http add urlacl url=http://+:5057/ user=Everyone' />

        <CustomAction Id="AddFileApiUrlAclBeforeInstall"
          Directory="SystemFolder"
          Execute="deferred"
          Impersonate="no"
          Return="ignore"
          ExeCommand='netsh.exe http add urlacl url=http://+:5065/ user=Everyone' />

    <CustomAction Id="AddSnapshotFirewallRuleBeforeInstall"
                  Directory="SystemFolder"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  ExeCommand='netsh.exe advfirewall firewall add rule name="IRIS Agent Snapshot TCP 5057" dir=in action=allow protocol=TCP localport=5057 profile=any' />

    <CustomAction Id="AddFileApiFirewallRuleBeforeInstall"
                  Directory="SystemFolder"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  ExeCommand='netsh.exe advfirewall firewall add rule name="IRIS Agent File API TCP 5065" dir=in action=allow protocol=TCP localport=5065 profile=any' />

    <CustomAction Id="ConfigurePipeToken"
                  Directory="SystemFolder"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"
                  ExeCommand='WindowsPowerShell\v1.0\powershell.exe -NoProfile -ExecutionPolicy Bypass -File "[INSTALLDIR]ConfigurePipeToken.ps1"' />

    <CustomAction Id="CreateAgentTask"
                  Directory="SystemFolder"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  ExeCommand='WindowsPowerShell\v1.0\powershell.exe -NoProfile -ExecutionPolicy Bypass -File "[INSTALLDIR]RegisterAgentStartupTask.ps1"' />

    <InstallExecuteSequence>
      <!-- Uninstall: clean up tasks, ACLs -->
      <Custom Action="DeleteAgentTask" After="InstallInitialize" Condition="REMOVE~=&quot;ALL&quot; AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="DeleteAgentHelperTask" After="DeleteAgentTask" Condition="REMOVE~=&quot;ALL&quot; AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="DeleteAgentWakeTask" After="DeleteAgentHelperTask" Condition="REMOVE~=&quot;ALL&quot; AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="RemoveSnapshotUrlAcl" After="DeleteAgentWakeTask" Condition="REMOVE~=&quot;ALL&quot; AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="RemoveFileApiUrlAcl" After="RemoveSnapshotUrlAcl" Condition="REMOVE~=&quot;ALL&quot; AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="RemoveSnapshotFirewallRule" After="RemoveFileApiUrlAcl" Condition="REMOVE~=&quot;ALL&quot; AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="RemoveFileApiFirewallRule" After="RemoveSnapshotFirewallRule" Condition="REMOVE~=&quot;ALL&quot; AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />

      <!-- Install: clean up old tasks/services, add ACLs, configure token, register new task -->
      <Custom Action="DeleteAgentTaskBeforeInstall" After="InstallFiles" Condition="NOT REMOVE AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="DeleteAgentHelperTaskBeforeInstall" After="DeleteAgentTaskBeforeInstall" Condition="NOT REMOVE AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="DeleteAgentWakeTaskBeforeInstall" After="DeleteAgentHelperTaskBeforeInstall" Condition="NOT REMOVE AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="StopLegacyAgentServiceBeforeInstall" After="DeleteAgentWakeTaskBeforeInstall" Condition="NOT REMOVE AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="DeleteLegacyAgentServiceBeforeInstall" After="StopLegacyAgentServiceBeforeInstall" Condition="NOT REMOVE AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="AddSnapshotUrlAclBeforeInstall" After="DeleteLegacyAgentServiceBeforeInstall" Condition="NOT REMOVE AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="AddFileApiUrlAclBeforeInstall" After="AddSnapshotUrlAclBeforeInstall" Condition="NOT REMOVE AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="AddSnapshotFirewallRuleBeforeInstall" After="AddFileApiUrlAclBeforeInstall" Condition="NOT REMOVE AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="AddFileApiFirewallRuleBeforeInstall" After="AddSnapshotFirewallRuleBeforeInstall" Condition="NOT REMOVE AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="ConfigurePipeToken" After="AddFileApiFirewallRuleBeforeInstall" Condition="NOT REMOVE AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
      <Custom Action="CreateAgentTask" After="ConfigurePipeToken" Condition="NOT REMOVE AND ENABLE_CUSTOM_BOOTSTRAP = &quot;1&quot;" />
    </InstallExecuteSequence>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="COMPANYFOLDER" Name="IRIS">
        <Directory Id="INSTALLDIR" Name="Agent" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="IRISStartMenuFolder" Name="IRIS" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <Component Id="StartMenuShortcutComponent" Directory="IRISStartMenuFolder" Guid="*">
      <Shortcut Id="AgentStartMenuShortcut"
                Name="IRIS Agent"
                Target="[INSTALLDIR]IRIS.Agent.exe"
                Arguments="--background"
                WorkingDirectory="INSTALLDIR"
                Description="IRIS Endpoint Agent" />
      <RemoveFolder Id="RemoveIRISStartMenuFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\IRIS\Agent" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="AgentFiles" Directory="INSTALLDIR">
      <Files Include="$(var.PayloadDir)\**">
        <Exclude Files="$(var.PayloadDir)\**\*.pdb" />
      </Files>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <Component Id="AgentTaskScriptComponent" Directory="INSTALLDIR" Guid="*">
      <File Id="RegisterAgentStartupTaskScript" Source="scripts\RegisterAgentStartupTask.ps1" />
    </Component>
  </Fragment>

  <Fragment>
    <Component Id="PipeTokenScriptComponent" Directory="INSTALLDIR" Guid="*">
      <File Id="ConfigurePipeTokenScript" Source="scripts\ConfigurePipeToken.ps1" />
    </Component>
  </Fragment>

</Wix>
