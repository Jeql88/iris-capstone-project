## Ignore Visual Studio temporary files, build results, and ##
## files generated by popular Visual Studio add-ons. ##

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio directories
.vs/
.vscode/

# NuGet Packages
packages/

# JetBrains Rider directory
.idea/

# ASP.NET Scaffolding generated files
ScaffoldingReadMe.txt

# Microsoft Azure Build Artifacts
csx/
*.build.csdef

# Others
*.ser
*.SQLITE
*.dbmdl
/IMPLEMENTATION_SUMMARY.md
/QUICK_REFERENCE.md
