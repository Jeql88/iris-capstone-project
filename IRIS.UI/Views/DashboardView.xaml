<UserControl x:Class="IRIS.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar Navigation -->
        <Border Grid.Column="0" Background="#6B1C1C">
            <StackPanel>
                <TextBlock Text="IRIS" FontSize="20" FontWeight="Bold" Foreground="White" Margin="20,20,20,40"/>
                
                <Button Content="Dashboard" Background="#8B0000" Foreground="White" FontSize="14" Height="45" HorizontalContentAlignment="Left" Padding="20,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Monitor" Background="Transparent" Foreground="White" FontSize="14" Height="45" HorizontalContentAlignment="Left" Padding="20,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Software Management" Background="Transparent" Foreground="White" FontSize="14" Height="45" HorizontalContentAlignment="Left" Padding="20,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Policy Enforcement" Background="Transparent" Foreground="White" FontSize="14" Height="45" HorizontalContentAlignment="Left" Padding="20,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Access Logs" Background="Transparent" Foreground="White" FontSize="14" Height="45" HorizontalContentAlignment="Left" Padding="20,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="User Management" Background="Transparent" Foreground="White" FontSize="14" Height="45" HorizontalContentAlignment="Left" Padding="20,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Usage Metrics" Background="Transparent" Foreground="White" FontSize="14" Height="45" HorizontalContentAlignment="Left" Padding="20,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Settings" Background="Transparent" Foreground="White" FontSize="14" Height="45" HorizontalContentAlignment="Left" Padding="20,0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,20,30,20">
                <!-- Header with Lab Selector -->
                <Grid Margin="0,0,0,25">
                    <TextBlock Text="Dashboard" FontSize="36" FontWeight="Bold" Foreground="#8B0000" VerticalAlignment="Center"/>
                    <ComboBox HorizontalAlignment="Right" Width="180" Height="40" FontSize="14" Background="#8B0000" Foreground="White" BorderThickness="0"
                              SelectedItem="{Binding SelectedLab}">
                        <ComboBoxItem Content="Archi Lab 1" IsSelected="True"/>
                        <ComboBoxItem Content="Archi Lab 2"/>
                        <ComboBoxItem Content="Archi Lab 3"/>
                        <ComboBoxItem Content="Archi Lab 4"/>
                    </ComboBox>
                </Grid>

                <!-- Top Row: Latency and Network Performance -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Latency Card -->
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="Latency (ms)" FontSize="20" FontWeight="Bold" Foreground="#D32F2F"/>
                                <TextBlock Text="Last 24 hours ▼" FontSize="12" Foreground="#D32F2F" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Average Latency (Today)" FontSize="14" Foreground="#666" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AverageLatency, StringFormat={}{0:F0}ms}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Border Height="220" Background="#FAFAFA" CornerRadius="8">
                                <TextBlock Text="[Latency Chart]" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#CCC" FontSize="14"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Network Performance Card -->
                    <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="Network Performance" FontSize="20" FontWeight="Bold" Foreground="#D32F2F"/>
                                <TextBlock Text="Last 24 hours ▼" FontSize="12" Foreground="#D32F2F" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Current Bandwidth Usage" FontSize="14" Foreground="#666"/>
                                <TextBlock Text="{Binding CurrentBandwidth, StringFormat={}{0:F1} Mbps}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Peak Usage (Today)" FontSize="14" Foreground="#666"/>
                                <TextBlock Text="{Binding PeakBandwidth, StringFormat={}{0:F1} Mbps}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Border Height="220" Background="#FAFAFA" CornerRadius="8">
                                <TextBlock Text="[Bandwidth Chart]" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#CCC" FontSize="14"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Bottom Row: Packet Loss and Heavy Applications -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.9*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1.1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Packet Loss Card -->
                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="Packet Loss %" FontSize="20" FontWeight="Bold" Foreground="#D32F2F"/>
                                <TextBlock Text="Last 24 hours ▼" FontSize="12" Foreground="#D32F2F" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <Border Height="280" Background="#FAFAFA" CornerRadius="8">
                                <TextBlock Text="[Packet Loss Chart]" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#CCC" FontSize="14"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Heavy Applications Monitor Card -->
                    <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Heavy Applications Monitor" FontSize="20" FontWeight="Bold" Foreground="#D32F2F" Margin="0,0,0,20"/>
                            <ItemsControl ItemsSource="{Binding HeavyApplications}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="45" Height="45" Background="#8B0000" CornerRadius="8">
                                                <TextBlock Text="{Binding Icon}" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" Foreground="#333"/>
                                                <TextBlock FontSize="13" Foreground="#888">
                                                    <Run Text="{Binding Instances}"/>
                                                    <Run Text="instances •"/>
                                                    <Run Text="{Binding RamUsage, StringFormat={}{0:F1}}"/>
                                                    <Run Text="GB RAM avg"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Right Sidebar: Active Lab PCs -->
        <Border Grid.Column="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
            <StackPanel Margin="25,20,25,20">
                <Grid Margin="0,0,0,20">
                    <TextBlock Text="Active Lab PCs" FontSize="20" FontWeight="Bold" Foreground="#333"/>
                    <TextBlock FontSize="13" Foreground="#666" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Run Text="{Binding OnlinePCs}"/>
                        <Run Text="/"/>
                        <Run Text="{Binding TotalPCs}"/>
                        <Run Text="Online"/>
                    </TextBlock>
                </Grid>
                <ItemsControl ItemsSource="{Binding LabStatuses}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#8B0000" CornerRadius="10" Padding="20,18" Margin="0,0,0,12">
                                <Grid>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ActivePCs}" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
    

</UserControl>
