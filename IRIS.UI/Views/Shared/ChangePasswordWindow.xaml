<ui:FluentWindow x:Class="IRIS.UI.Views.Shared.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Change Password Required" Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    
    <Grid Margin="30">
        <ui:Card>
            <StackPanel Margin="20">
                <!-- Warning Icon -->
                <ui:SymbolIcon Symbol="Warning24" 
                               FontSize="48" 
                               Foreground="{DynamicResource IRISSecondaryBrush}"
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,20"/>
                
                <!-- Title -->
                <TextBlock Text="Password Change Required" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource IRISSecondaryBrush}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,10"/>
                
                <!-- Subtitle -->
                <TextBlock Text="You must change your password before continuing." 
                           FontSize="14" 
                           Foreground="#666666" 
                           HorizontalAlignment="Center" 
                           TextWrapping="Wrap" 
                           TextAlignment="Center" 
                           Margin="0,0,0,30"/>
                
                <!-- Current Password -->
                <TextBlock Text="Current Password" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,8"
                           Foreground="#1a1a1a"/>
                <ui:PasswordBox x:Name="CurrentPasswordBox" 
                                PlaceholderText="Enter current password"
                                Icon="{ui:SymbolIcon LockClosed24}"
                                Margin="0,0,0,15"/>
                
                <!-- New Password -->
                <TextBlock Text="New Password" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,8"
                           Foreground="#1a1a1a"/>
                <ui:PasswordBox x:Name="NewPasswordBox" 
                                PlaceholderText="Enter new password"
                                Icon="{ui:SymbolIcon Key24}"
                                Margin="0,0,0,15"/>
                
                <!-- Confirm Password -->
                <TextBlock Text="Confirm New Password" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,8"
                           Foreground="#1a1a1a"/>
                <ui:PasswordBox x:Name="ConfirmPasswordBox" 
                                PlaceholderText="Confirm new password"
                                Icon="{ui:SymbolIcon Checkmark24}"
                                Margin="0,0,0,25"/>
                
                <!-- Change Password Button -->
                <ui:Button x:Name="ChangePasswordButton" 
                          Content="Change Password" 
                          Appearance="Primary"
                          HorizontalAlignment="Stretch"
                          Height="45"
                          FontSize="14"
                          FontWeight="SemiBold"
                          Icon="{ui:SymbolIcon ArrowRight24}"
                          Click="ChangePassword_Click"/>
            </StackPanel>
        </ui:Card>
    </Grid>
</ui:FluentWindow>
