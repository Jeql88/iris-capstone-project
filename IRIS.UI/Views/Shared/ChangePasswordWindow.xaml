<ui:FluentWindow x:Class="IRIS.UI.Views.Shared.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Change Password Required" Height="600" Width="500" MinHeight="560" MinWidth="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    
    <Grid Margin="24">
        <ui:Card>
            <StackPanel Margin="18">
                
                <!-- Title -->
                <TextBlock Text="Password Change Required" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource IRISSecondaryBrush}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,8"/>
                
                <!-- Subtitle -->
                <TextBlock Text="You must change your password before continuing." 
                           FontSize="14" 
                           Foreground="#666666" 
                           HorizontalAlignment="Center" 
                           TextWrapping="Wrap" 
                           TextAlignment="Center" 
                           Margin="0,0,0,22"/>
                
                <!-- Current Password -->
                <TextBlock Text="Current Password" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <ui:PasswordBox x:Name="CurrentPasswordBox" 
                                PlaceholderText="Enter current password"
                                Icon="{ui:SymbolIcon LockClosed24}"
                                Margin="0,0,0,15"/>
                
                <!-- New Password -->
                <TextBlock Text="New Password" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <ui:PasswordBox x:Name="NewPasswordBox" 
                                PlaceholderText="Enter new password"
                                Icon="{ui:SymbolIcon Key24}"
                                Margin="0,0,0,15"/>
                
                <!-- Confirm Password -->
                <TextBlock Text="Confirm New Password" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                <ui:PasswordBox x:Name="ConfirmPasswordBox" 
                                PlaceholderText="Confirm new password"
                                Icon="{ui:SymbolIcon Checkmark24}"
                                Margin="0,0,0,8"/>

                <TextBlock x:Name="ErrorMessageTextBlock" Text="" FontSize="12" Margin="0,0,0,17" Foreground="#B00020" Visibility="Collapsed"/>
                
                <!-- Change Password Button -->
                <ui:Button x:Name="ChangePasswordButton"
                          Content="Change Password"
                          Appearance="Primary"
                          HorizontalAlignment="Stretch"
                          Height="45"
                          FontSize="14"
                          FontWeight="SemiBold"
                          Icon="{ui:SymbolIcon ArrowRight24}"
                          Click="ChangePassword_Click"
                          Cursor="Hand"/>
            </StackPanel>
        </ui:Card>
    </Grid>
</ui:FluentWindow>
