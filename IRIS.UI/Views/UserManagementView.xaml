<UserControl x:Class="IRIS.UI.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: User List Section -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,20">
                <!-- Header -->
                <TextBlock Text="User Management" FontSize="36" FontWeight="Bold" 
                           Foreground="#8B0000" Margin="0,0,0,25"/>

                <!-- Search and Filters Card -->
                <Border Background="White" CornerRadius="8" Padding="25" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Search Users" FontSize="20" FontWeight="Bold" 
                                   Foreground="#DC143C" Margin="0,0,0,20"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search Box -->
                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="Search" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White">
                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                             Height="40" Padding="12,0" FontSize="14" 
                                             BorderThickness="0" Background="Transparent"
                                             VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <!-- Role Filter -->
                            <StackPanel Grid.Column="1" Margin="0,0,15,0">
                                <TextBlock Text="Roles" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White">
                                    <ComboBox SelectedValue="{Binding SelectedRole, Mode=TwoWay}" 
                                              SelectedValuePath="Content"
                                              Height="40" FontSize="14"
                                              BorderThickness="0" Background="Transparent" Padding="12,0"
                                              VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="All Roles" IsSelected="True"/>
                                        <ComboBoxItem Content="System Administrator"/>
                                        <ComboBoxItem Content="IT Personnel"/>
                                        <ComboBoxItem Content="Faculty"/>
                                    </ComboBox>
                                </Border>
                            </StackPanel>

                            <!-- Status Filter -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Status" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White">
                                    <ComboBox SelectedValue="{Binding SelectedStatus, Mode=TwoWay}" 
                                              SelectedValuePath="Content"
                                              Height="40" FontSize="14"
                                              BorderThickness="0" Background="Transparent" Padding="12,0"
                                              VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="All Status" IsSelected="True"/>
                                        <ComboBoxItem Content="Active"/>
                                        <ComboBoxItem Content="Inactive"/>
                                    </ComboBox>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Users Table Card -->
                <Border Background="White" CornerRadius="8" Padding="25">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Table Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="System Users" FontSize="20" FontWeight="Bold" Foreground="#DC143C"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Showing " FontSize="13" Foreground="#DC143C"/>
                                <TextBlock Text="{Binding FilteredUsers.Count}" FontSize="13" Foreground="#DC143C" FontWeight="SemiBold"/>
                                <TextBlock Text=" entries" FontSize="13" Foreground="#DC143C"/>
                            </StackPanel>
                        </Grid>

                        <!-- DataGrid -->
                        <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredUsers}" 
                                  SelectedItem="{Binding SelectedUser}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  Background="White" BorderThickness="0"
                                  RowBackground="White" AlternatingRowBackground="#FFF5F5"
                                  MinHeight="400" HorizontalGridLinesBrush="#F0F0F0"
                                  CanUserResizeColumns="False">
                            
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#333"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="12,12"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Foreground" Value="#333"/>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="2*"/>
                                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="2*"/>
                                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="1.5*"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT: Add/Edit User Sidebar -->
        <Border Grid.Column="1" Background="#FAFAFA">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Add New User Section -->
                    <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Add New User" FontSize="20" FontWeight="Bold" Foreground="#DC143C" Margin="0,0,0,20"/>
                            
                            <TextBlock Text="Full Name" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,15">
                                <TextBox x:Name="AddFullNameTextBox" Height="40" Padding="12,0" FontSize="14" 
                                         BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center"/>
                            </Border>
                            
                            <TextBlock Text="Username" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,15">
                                <TextBox x:Name="AddUsernameTextBox" Height="40" Padding="12,0" FontSize="14" 
                                         BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center"/>
                            </Border>
                            
                            <TextBlock Text="Role" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,20">
                                <ComboBox x:Name="AddRoleComboBox" Height="40" FontSize="14" BorderThickness="0" Background="Transparent" Padding="12,0"
                                          VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="System Administrator"/>
                                    <ComboBoxItem Content="IT Personnel"/>
                                    <ComboBoxItem Content="Faculty" IsSelected="True"/>
                                </ComboBox>
                            </Border>
                            
                            <Button x:Name="AddUserButton" Content="+ Add New User" Background="#DC143C" Foreground="White" 
                                    Height="40" FontSize="14" FontWeight="SemiBold" 
                                    BorderThickness="0" Cursor="Hand" Click="AddUser_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Manage User Section -->
                    <Border Background="White" CornerRadius="8" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Manage User" FontSize="20" FontWeight="Bold" Foreground="#DC143C" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="HelpIcon" Text="?" FontSize="14" FontWeight="Bold" 
                                           Foreground="White" Background="#999" 
                                           Width="20" Height="20" TextAlignment="Center" 
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Padding="0,1,0,0" ToolTip="Select a user from the table to edit">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Cursor" Value="Help"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#666"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            
                            
                            <TextBlock Text="Full Name" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,15">
                                <TextBox x:Name="EditFullNameTextBox" Height="40" Padding="12,0" FontSize="14" 
                                         BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center" IsEnabled="False"/>
                            </Border>
                            
                            <TextBlock Text="Username" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,15">
                                <TextBox x:Name="EditUsernameTextBox" Height="40" Padding="12,0" FontSize="14" 
                                         BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center" IsEnabled="False"/>
                            </Border>
                            
                            <TextBlock Text="Role" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,20">
                                <ComboBox x:Name="EditRoleComboBox" Height="40" FontSize="14"
                                          BorderThickness="0" Background="Transparent" Padding="12,0"
                                          VerticalContentAlignment="Center" IsEnabled="False">
                                    <ComboBoxItem Content="System Administrator"/>
                                    <ComboBoxItem Content="IT Personnel"/>
                                    <ComboBoxItem Content="Faculty"/>
                                </ComboBox>
                            </Border>
                            
                            <!-- Clear Selection Button -->
                            <Button x:Name="ClearSelectionButton" Content="✕ Clear Selection" Background="#F5F5F5" Foreground="#666" 
                                    Height="35" FontSize="13" FontWeight="SemiBold" 
                                    BorderThickness="1" BorderBrush="#DDD" Cursor="Hand" Margin="0,0,0,15"
                                    Click="ClearSelection_Click" Visibility="Collapsed">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <Button x:Name="EditUserButton" Content="✏ Edit User" Background="White" Foreground="#DC143C" 
                                    Height="40" FontSize="14" FontWeight="SemiBold" 
                                    BorderThickness="1" BorderBrush="#DC143C" Cursor="Hand" Margin="0,0,0,10"
                                    IsEnabled="False" Click="EditUser_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            
                            <Button x:Name="DeactivateUserButton" Content="🗑 Deactivate User" Background="#DC143C" Foreground="White" 
                                    Height="40" FontSize="14" FontWeight="SemiBold" 
                                    BorderThickness="0" Cursor="Hand" IsEnabled="False" Click="DeactivateUser_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
