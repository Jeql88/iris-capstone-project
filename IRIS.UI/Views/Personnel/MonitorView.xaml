<UserControl x:Class="IRIS.UI.Views.Personnel.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:IRIS.UI.Converters">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <converters:Base64ToImageSourceConverter x:Key="Base64ToImageSourceConverter"/>
    </UserControl.Resources>

    <Grid>
        <!-- Main content -->
        <Grid Margin="16,10,16,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Desktop24" FontSize="32" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,12,0"/>
                    <TextBlock Text="PC Monitoring" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Margin="8,0,0,0"
                               Height="32"
                               Icon="{ui:SymbolIcon ArrowClockwise24}"
                               Command="{Binding RefreshCommand}"
                               Appearance="Secondary"
                               ToolTip="Refresh"/>
                </StackPanel>
            </Grid>

            <!-- Stats cards -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Total -->
                <ui:Card Grid.Column="0" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource ControlFillColorTertiaryBrush}" Margin="0,0,10,0">
                            <ui:SymbolIcon Symbol="Desktop24" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Total PCs" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalPCCount}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </ui:Card>

                <!-- Online -->
                <ui:Card Grid.Column="2" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0">
                            <Border.Background>
                                <SolidColorBrush Color="#1610B981" />
                            </Border.Background>
                            <Ellipse Width="10" Height="10" Fill="{DynamicResource OnlineStatusBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Online" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding OnlinePCCount}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource OnlineStatusBrush}"/>
                        </StackPanel>
                    </Grid>
                </ui:Card>

                <!-- Offline -->
                <ui:Card Grid.Column="4" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0">
                            <Border.Background>
                                <SolidColorBrush Color="#16EF4444" />
                            </Border.Background>
                            <Ellipse Width="10" Height="10" Fill="{DynamicResource OfflineStatusBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Offline" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding OfflinePCCount}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource OfflineStatusBrush}"/>
                        </StackPanel>
                    </Grid>
                </ui:Card>

                <!-- Alert summary -->
                <ui:Card Grid.Column="6" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource ControlFillColorTertiaryBrush}" Margin="0,0,10,0">
                            <ui:SymbolIcon Symbol="Alert24" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding AlertHeaderText}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Text="{Binding TopAlertMessage}" FontSize="11" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </ui:Card>
            </Grid>

            <!-- Filters -->
            <ui:Card Grid.Row="2" Padding="15" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="Filter24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Filter PCs" FontSize="18" FontWeight="Bold" 
                                   Foreground="{DynamicResource IRISSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="Search" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:TextBox PlaceholderText="Search PCs..." Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                                <ui:TextBox.Icon>
                                    <ui:SymbolIcon Symbol="Search24"/>
                                </ui:TextBox.Icon>
                            </ui:TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                            <TextBlock Text="Status" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ComboBox SelectedValue="{Binding SelectedPcStatus, Mode=TwoWay}" SelectedValuePath="Content">
                                <ComboBoxItem Content="All Statuses" IsSelected="True"/>
                                <ComboBoxItem Content="Online Only" />
                                <ComboBoxItem Content="Offline Only" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Laboratory" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ComboBox ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RoomNumber}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <ui:Button Content="Apply Filters"
                                   Command="{Binding ApplyFiltersCommand}"
                                   Appearance="Primary"
                                   Margin="0,0,10,0"/>
                        <ui:Button Content="Reset"
                                   Command="{Binding ResetFiltersCommand}"
                                   Appearance="Secondary"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- PC Grid (full width) -->
            <Grid Grid.Row="3">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                    <ItemsControl ItemsSource="{Binding FilteredPCs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="220" Margin="0,0,10,10" CornerRadius="10" Cursor="Hand"
                                        MouseLeftButtonDown="PCCard_Click" Tag="{Binding}">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <StackPanel>
                                                <TextBlock Text="{Binding PCName}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding IPAddress, StringFormat=IP: {0}}"/>
                                                <TextBlock Text="{Binding RoomName, StringFormat=Room: {0}}"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource IRISSecondaryBrush}"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource IRISPrimaryBrush}"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid Margin="10">
                                        <!-- Front face -->
                                        <Grid>
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFlipped}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>

                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Thumbnail -->
                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                <Border Width="196" Height="110" CornerRadius="8"
                                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                        HorizontalAlignment="Center" ClipToBounds="True">
                                                    <Grid>
                                                        <ui:SymbolIcon Symbol="Desktop24" FontSize="22"
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <Image Source="{Binding SnapshotImageBase64, Converter={StaticResource Base64ToImageSourceConverter}}"
                                                               Stretch="UniformToFill"/>
                                                    </Grid>
                                                </Border>

                                                <!-- Status dot -->
                                                <Ellipse Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0"
                                                         Fill="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                         Stroke="{DynamicResource SolidBackgroundFillColorBaseBrush}" StrokeThickness="2"/>

                                                <!-- Alert badge -->
                                                <ui:Badge HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2,2,0,0">
                                                    <ui:Badge.Style>
                                                        <Style TargetType="ui:Badge">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TopAlertSeverity}" Value="High">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Appearance" Value="Caution"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding TopAlertSeverity}" Value="Critical">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Appearance" Value="Danger"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:Badge.Style>
                                                    <TextBlock Text="!" FontWeight="Bold" FontSize="9"/>
                                                </ui:Badge>

                                                <!-- Alert count button -->
                                                <ui:Button HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                           Margin="0,0,2,2" Padding="4,1"
                                                           Command="{Binding DataContext.OpenPcAlertsForPCCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding}" Appearance="Secondary">
                                                    <ui:Button.Style>
                                                        <Style TargetType="ui:Button">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AlertCount}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:Button.Style>
                                                    <TextBlock Text="{Binding AlertCount, StringFormat={}⚠ {0}}" FontSize="10" FontWeight="SemiBold"/>
                                                </ui:Button>
                                            </Grid>

                                            <!-- PC name -->
                                            <TextBlock Grid.Row="1" Text="{Binding PCName}" FontWeight="SemiBold" FontSize="13"
                                                       HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                                            <!-- Stats chips -->
                                            <Grid Grid.Row="2" Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" CornerRadius="6" Padding="4,2" Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                    <TextBlock Text="{Binding CPU, StringFormat=CPU {0}}" FontSize="10" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </Border>
                                                <Border Grid.Column="2" CornerRadius="6" Padding="4,2" Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                    <TextBlock Text="{Binding RAM, StringFormat=RAM {0}}" FontSize="10" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </Border>
                                                <Border Grid.Column="4" CornerRadius="6" Padding="4,2" Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                    <TextBlock Text="{Binding Network, StringFormat=NET {0}}" FontSize="10" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </Border>
                                            </Grid>

                                            <!-- Status badge -->
                                            <ui:Badge Grid.Row="3" Margin="0,6,0,0" HorizontalAlignment="Center">
                                                <ui:Badge.Style>
                                                    <Style TargetType="ui:Badge">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Online">
                                                                <Setter Property="Appearance" Value="Success"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Offline">
                                                                <Setter Property="Appearance" Value="Danger"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:Badge.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="10"/>
                                            </ui:Badge>

                                            <!-- Quick actions -->
                                            <Grid Grid.Row="4" Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- View Screen button -->
                                                <ui:Button Grid.Column="1" Padding="6,3" Appearance="Secondary" ToolTip="View Screen"
                                                           Command="{Binding DataContext.ViewScreenForPCCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                           CommandParameter="{Binding}">
                                                    <ui:SymbolIcon Symbol="Eye24" FontSize="12"/>
                                                </ui:Button>

                                                <!-- More actions button with popup menu -->
                                                <ui:Button Grid.Column="3" Padding="6,3" Appearance="Secondary" ToolTip="More actions"
                                                           Click="MenuButton_Click">
                                                    <ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="12"/>
                                                </ui:Button>

                                                <!-- Popup menu -->
                                                <Popup x:Name="ContextMenuPopup" Grid.Column="3"
                                                       StaysOpen="False" AllowsTransparency="True"
                                                       Placement="Top" VerticalOffset="-4"
                                                       PopupAnimation="Fade">
                                                    <Border CornerRadius="8" Padding="4"
                                                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                            BorderThickness="1">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="12" Opacity="0.2" ShadowDepth="4"/>
                                                        </Border.Effect>
                                                        <StackPanel>
                                                            <ui:Button Padding="10,6" Appearance="Secondary"
                                                                       HorizontalContentAlignment="Left" HorizontalAlignment="Stretch"
                                                                       Click="HealthTimeline_Click">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <ui:SymbolIcon Symbol="HeartPulse24" FontSize="14" Margin="0,0,8,0"/>
                                                                    <TextBlock Text="Health Timeline" FontSize="12" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </ui:Button>
                                                            <ui:Button Padding="10,6" Appearance="Secondary"
                                                                       HorizontalContentAlignment="Left" HorizontalAlignment="Stretch"
                                                                       Click="RemoteDesktop_Click">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <ui:SymbolIcon Symbol="Desktop24" FontSize="14" Margin="0,0,8,0"/>
                                                                    <TextBlock Text="Remote Desktop" FontSize="12" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </ui:Button>
                                                            <ui:Button Padding="10,6" Appearance="Secondary"
                                                                       HorizontalContentAlignment="Left" HorizontalAlignment="Stretch"
                                                                       Click="Freeze_Click">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <ui:SymbolIcon Symbol="LockClosed24" FontSize="14" Margin="0,0,8,0"/>
                                                                    <TextBlock FontSize="12" VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="Freeze"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsFreezeActive}" Value="True">
                                                                                        <Setter Property="Text" Value="Unfreeze"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </ui:Button>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                        </Grid>

                                        <!-- Back face (details) -->
                                        <Border CornerRadius="8" Padding="10" Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFlipped}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Text="{Binding PCName}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Row="1" Margin="0,4,0,0" Text="{Binding OS}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Grid.Row="2" Margin="0,4,0,0" Text="{Binding CPUTemperature, StringFormat=CPU Temp: {0}}" FontSize="11" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Row="3" Margin="0,2,0,0" Text="{Binding GPUTemperature, StringFormat=GPU Temp: {0}}" FontSize="11" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Row="4" Margin="0,2,0,0" Text="{Binding NetworkDownload, StringFormat=↓ {0}}" FontSize="11" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Row="5" Margin="0,2,0,0" Text="{Binding NetworkUpload, StringFormat=↑ {0}}" FontSize="11" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Row="6" Margin="0,2,0,0" Text="{Binding NetworkLatency, StringFormat=Latency: {0}}" FontSize="11" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Grid.Row="7" Margin="0,2,0,0" Text="{Binding PacketLoss, StringFormat=Loss: {0}}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <StackPanel Grid.Row="8" Margin="0,8,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <ui:Button Content="View Screen" Icon="{ui:SymbolIcon Eye24}" Appearance="Primary"
                                                               Command="{Binding DataContext.ViewScreenForPCCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               CommandParameter="{Binding}" Padding="8,4" FontSize="11"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty state -->
                <Border Visibility="{Binding HasNoPCs, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Desktop24" FontSize="48" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="No PCs Found" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,6" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Select a laboratory or wait for PCs to connect" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== Alerts Popup Overlay ===== -->
        <Border Visibility="{Binding IsPcAlertsPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="#66000000">
            <Border Width="520" MaxHeight="500"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="12" Padding="20"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Symbol="Alert24" FontSize="18" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding SelectedPcAlertsTitle}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Dismiss24}" Appearance="Secondary"
                                   Command="{Binding ClosePcAlertsPanelCommand}" Padding="4"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" MaxHeight="380" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedPcAlerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Margin="0,0,0,8" Padding="12"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                                <ui:Badge Margin="0,0,10,0" VerticalAlignment="Top">
                                                    <ui:Badge.Style>
                                                        <Style TargetType="ui:Badge">
                                                            <Setter Property="Appearance" Value="Caution"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                    <Setter Property="Appearance" Value="Danger"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="High">
                                                                    <Setter Property="Appearance" Value="Caution"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:Badge.Style>
                                                    <TextBlock Text="{Binding Severity}" FontSize="10"/>
                                                </ui:Badge>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontWeight="SemiBold" FontSize="12"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding Type}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,12,0"/>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:MMM dd HH:mm:ss}}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Border>

        <!-- ===== Timeline Popup Overlay ===== -->
        <Border Visibility="{Binding IsTimelinePanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="#66000000">
            <Border Width="560" MaxHeight="600"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="12" Padding="20"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Symbol="HeartPulse24" FontSize="18" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedPcTimelineTitle}" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="Past 24 hours" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon ArrowClockwise24}" Appearance="Secondary"
                                   Command="{Binding RefreshSelectedPcTimelineCommand}" Padding="4" Margin="0,0,6,0" ToolTip="Refresh timeline"/>
                        <ui:Button Grid.Column="3" Icon="{ui:SymbolIcon Dismiss24}" Appearance="Secondary"
                                   Command="{Binding CloseTimelinePanelCommand}" Padding="4"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SelectedPcTimeline}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Padding="12" CornerRadius="8"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <ui:Badge Margin="0,0,10,0" VerticalAlignment="Top">
                                                    <ui:Badge.Style>
                                                        <Style TargetType="ui:Badge">
                                                            <Setter Property="Appearance" Value="Info"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Severity}" Value="High">
                                                                    <Setter Property="Appearance" Value="Caution"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                    <Setter Property="Appearance" Value="Danger"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                                    <Setter Property="Appearance" Value="Caution"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ui:Badge.Style>
                                                    <TextBlock Text="{Binding Severity}" FontSize="10"/>
                                                </ui:Badge>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding RelativeTime}" FontSize="10" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" FontSize="10" HorizontalAlignment="Right" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Loading -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsTimelineLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ui:ProgressRing IsIndeterminate="True" Width="36" Height="36"/>
                            <TextBlock Text="Loading timeline..." Margin="0,10,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Empty state -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasTimelineEvents}" Value="False"/>
                                                <Condition Binding="{Binding IsTimelineLoading}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ui:SymbolIcon Symbol="HeartPulse24" FontSize="32" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Margin="0,8,0,0" Text="{Binding TimelineEmptyMessage}" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
