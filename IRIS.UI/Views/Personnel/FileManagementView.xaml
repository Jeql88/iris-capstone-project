<UserControl x:Class="IRIS.UI.Views.Personnel.FileManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="File Management" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource IRISPrimaryBrush}"/>
            <TextBlock Text="Browse, upload, download, and manage remote files on lab PCs through agents."
                       Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <ComboBox Width="200" Margin="0,0,10,0" ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RoomNumber}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox Width="260" ItemsSource="{Binding PCs}" SelectedItem="{Binding SelectedFileManagementPC}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Hostname}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ui:TextBox Width="360" Margin="10,0,0,0" Text="{Binding CurrentRemotePath, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Remote path (relative to agent root)"/>
                    <ui:Button Margin="10,0,0,0" Content="Load" Command="{Binding LoadRemoteFilesCommand}" Appearance="Secondary"/>
                    <ui:Button Margin="10,0,0,0" Content="Up" Command="{Binding NavigateUpRemotePathCommand}" Appearance="Secondary" IsEnabled="{Binding CanNavigateUp}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                    <ui:TextBox Width="360" Text="{Binding RemoteSearchText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Search current folder..."/>
                    <ui:Button Margin="10,0,0,0" Content="Search" Command="{Binding SearchRemoteFilesCommand}" Appearance="Secondary"/>
                    <ui:Button Margin="10,0,0,0" Content="Clear Search" Appearance="Secondary" Command="{Binding ClearRemoteSearchCommand}"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,12,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="8" BorderThickness="2" BorderBrush="{DynamicResource IRISPrimaryBrush}"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        AllowDrop="True" Drop="FileDropZone_Drop" DragOver="FileDropZone_DragOver" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Drag and drop local files here for upload" FontWeight="SemiBold"/>
                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding PendingUploadFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,2,0,2">
                                        <TextBlock DockPanel.Dock="Left" Text="{Binding}" TextTrimming="CharacterEllipsis" Width="460"/>
                                        <ui:Button DockPanel.Dock="Right" Content="Remove" Appearance="Secondary"
                                                   Command="{Binding DataContext.RemovePendingUploadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   CommandParameter="{Binding}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <ui:Button Content="Browse Local Files" Command="{Binding BrowseUploadFilesCommand}" Appearance="Secondary" Margin="0,0,0,8"/>
                    <ui:Button Content="Upload to Selected PCs" Command="{Binding UploadFilesCommand}" Appearance="Primary"/>
                </StackPanel>
            </Grid>

            <DataGrid x:Name="RemoteFilesGrid" Grid.Row="2" ItemsSource="{Binding RemoteFiles}" SelectedItem="{Binding SelectedRemoteFile}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MouseDoubleClick="RemoteFilesGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding TypeText}" Width="90"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="100"/>
                    <DataGridTextColumn Header="Last Modified (UTC)" Binding="{Binding LastWriteTimeUtc, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="180"/>
                    <DataGridTemplateColumn Header="Actions" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button Content="Download" Appearance="Secondary" Margin="0,0,8,0"
                                               Command="{Binding DataContext.DownloadRemoteFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               CommandParameter="{Binding}"/>
                                    <ui:Button Content="Delete" Appearance="Danger"
                                               Command="{Binding DataContext.DeleteRemoteFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Margin="0,10,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
    </Grid>
</UserControl>
