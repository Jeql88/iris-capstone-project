<UserControl x:Class="IRIS.UI.Views.Personnel.FileManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:IRIS.UI.Converters">

    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <conv:BooleanToVisibilityConverter x:Key="InvertBoolToVisConverter"/>
        <conv:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <conv:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter"/>

        <!-- DataGrid row hover / selection highlight styles -->
        <Style x:Key="FileGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="MinHeight" Value="30"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#18808080"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#30DC3545"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#44DC3545"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FileGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="28" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,10,0"/>
                <TextBlock Text="File Management" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Dual-pane file explorer — Local (left) and Remote (right). Drag files from local to remote to upload."
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- ═══ PC SELECTOR ═══ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Room:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox Width="160" Margin="0,0,12,0"
                      ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding RoomNumber}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="PC:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox Width="240" ItemsSource="{Binding PCs}" SelectedItem="{Binding SelectedPC}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Hostname}"/>
                            <TextBlock Text=" (" Foreground="Gray"/>
                            <TextBlock Text="{Binding IPAddress}" Foreground="Gray"/>
                            <TextBlock Text=")" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <ui:Button Margin="12,0,0,0" Content="Refresh PCs" Command="{Binding RefreshPCsCommand}" Appearance="Secondary"/>
        </StackPanel>

        <!-- ═══ DUAL PANE ═══ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT PANE: Local Files ─── -->
            <Border Grid.Column="0" CornerRadius="6" BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📁 Local Files (This PC)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>

                    <!-- Navigation bar -->
                    <Grid Grid.Row="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0" Margin="0,0,4,0" ToolTip="Drives"
                                   Command="{Binding GoToLocalDrivesCommand}" Padding="6,4">
                            <ui:SymbolIcon Symbol="Home24"/>
                        </ui:Button>
                        <ui:Button Grid.Column="1" Margin="0,0,4,0" ToolTip="Up"
                                   Command="{Binding NavigateUpLocalCommand}" Padding="6,4">
                            <ui:SymbolIcon Symbol="ArrowUp24"/>
                        </ui:Button>
                        <ui:TextBox Grid.Column="2"
                                    Text="{Binding CurrentLocalPath, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Path..."
                                    KeyDown="LocalPathBox_KeyDown"/>
                        <ui:Button Grid.Column="3" Margin="4,0,0,0" Content="Go"
                                   Command="{Binding NavigateToLocalPathCommand}" Appearance="Secondary" Padding="10,4"/>
                    </Grid>

                    <!-- File list -->
                    <DataGrid x:Name="LocalFilesGrid" Grid.Row="2"
                              ItemsSource="{Binding LocalFiles}"
                              SelectedItem="{Binding SelectedLocalFile}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              MouseDoubleClick="LocalFilesGrid_MouseDoubleClick"
                              PreviewMouseLeftButtonDown="LocalFilesGrid_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="LocalFilesGrid_PreviewMouseMove"
                              PreviewMouseRightButtonDown="LocalFilesGrid_PreviewMouseRightButtonDown"
                              SelectionChanged="LocalFilesGrid_SelectionChanged"
                              SelectionMode="Extended" GridLinesVisibility="None"
                              HeadersVisibility="Column" BorderThickness="0"
                              RowHeaderWidth="0"
                              RowStyle="{StaticResource FileGridRowStyle}"
                              CellStyle="{StaticResource FileGridCellStyle}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Upload to Remote"
                                          Command="{Binding UploadLocalFileCommand}">
                                    <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowUpload24" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Open File Location"
                                          Command="{Binding OpenFileLocationCommand}">
                                    <MenuItem.Icon><ui:SymbolIcon Symbol="FolderOpen24" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Rename"
                                          Command="{Binding RenameLocalFileCommand}"
                                          CommandParameter="{Binding SelectedLocalFile}">
                                    <MenuItem.Icon><ui:SymbolIcon Symbol="Rename24" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Delete"
                                          Command="{Binding DeleteLocalFileCommand}">
                                    <MenuItem.Icon><ui:SymbolIcon Symbol="Delete24" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="" Binding="{Binding DisplayIcon}" Width="30" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeText}" Width="80"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="80"/>
                            <DataGridTextColumn Header="Modified" Binding="{Binding DateText}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- ─── RIGHT PANE: Remote Files ─── -->
            <Border Grid.Column="2" CornerRadius="6" BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="8"
                    AllowDrop="True" Drop="RemotePane_Drop" DragOver="RemotePane_DragOver">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🌐 Remote Files" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>

                    <!-- Navigation bar -->
                    <Grid Grid.Row="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ui:Button Grid.Column="0" Margin="0,0,4,0" ToolTip="Drives"
                                   Command="{Binding GoToRemoteDrivesCommand}" Padding="6,4">
                            <ui:SymbolIcon Symbol="Home24"/>
                        </ui:Button>
                        <ui:Button Grid.Column="1" Margin="0,0,4,0" ToolTip="Up"
                                   Command="{Binding NavigateUpRemoteCommand}" Padding="6,4">
                            <ui:SymbolIcon Symbol="ArrowUp24"/>
                        </ui:Button>
                        <ui:TextBox Grid.Column="2"
                                    Text="{Binding CurrentRemotePath, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Remote path..."
                                    KeyDown="RemotePathBox_KeyDown"/>
                        <ui:Button Grid.Column="3" Margin="4,0,0,0" Content="Go"
                                   Command="{Binding NavigateToRemotePathCommand}" Appearance="Secondary" Padding="10,4"/>
                    </Grid>

                    <!-- File list -->
                    <DataGrid x:Name="RemoteFilesGrid" Grid.Row="2"
                              ItemsSource="{Binding RemoteFiles}"
                              SelectedItem="{Binding SelectedRemoteFile}"
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              MouseDoubleClick="RemoteFilesGrid_MouseDoubleClick"
                              PreviewMouseRightButtonDown="RemoteFilesGrid_PreviewMouseRightButtonDown"
                              SelectionChanged="RemoteFilesGrid_SelectionChanged"
                              SelectionMode="Extended" GridLinesVisibility="None"
                              HeadersVisibility="Column" BorderThickness="0"
                              RowHeaderWidth="0"
                              RowStyle="{StaticResource FileGridRowStyle}"
                              CellStyle="{StaticResource FileGridCellStyle}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Download to Local"
                                          Command="{Binding DownloadRemoteFileCommand}">
                                    <MenuItem.Icon><ui:SymbolIcon Symbol="ArrowDownload24" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Rename"
                                          Command="{Binding RenameRemoteFileCommand}"
                                          CommandParameter="{Binding SelectedRemoteFile}">
                                    <MenuItem.Icon><ui:SymbolIcon Symbol="Rename24" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Delete"
                                          Command="{Binding DeleteRemoteFileCommand}">
                                    <MenuItem.Icon><ui:SymbolIcon Symbol="Delete24" FontSize="14"/></MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="" Binding="{Binding DisplayIcon}" Width="30" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeText}" Width="80"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="80"/>
                            <DataGridTextColumn Header="Modified" Binding="{Binding DateText}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ BULK UPLOAD SECTION ═══ -->
        <Border Grid.Row="3" CornerRadius="6" BorderThickness="1" Margin="0,8,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                Background="{DynamicResource ControlFillColorDefaultBrush}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📦 Bulk Upload to Multiple PCs" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>

                <!-- Row 1: Folder name + file selection -->
                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Remote Folder Name:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ui:TextBox Grid.Column="1"
                                Text="{Binding BulkFolderName, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="e.g. Assignment_01"/>
                    <ui:Button Grid.Column="2" Content="Browse Files" Margin="12,0,0,0"
                               Command="{Binding BrowseBulkFilesCommand}" Appearance="Secondary"/>
                    <TextBlock Grid.Column="3" VerticalAlignment="Center" Margin="12,0,0,0"
                               Text="{Binding BulkPendingFiles.Count, StringFormat='{}{0} file(s) selected'}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:Button Grid.Column="4" Content="Start Bulk Upload" Margin="12,0,0,0"
                               Command="{Binding StartBulkUploadCommand}" Appearance="Primary"/>
                </Grid>

                <!-- Row 2: Target PC mode -->
                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Target:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <RadioButton Grid.Column="1" Content="All PCs in room" Margin="0,0,16,0"
                                 IsChecked="{Binding BulkUploadToAll}" GroupName="BulkTarget"/>
                    <RadioButton Grid.Column="2" Content="Selected PCs only" Margin="0,0,12,0"
                                 IsChecked="{Binding BulkUploadToAll, Converter={StaticResource InvertBoolConverter}}" GroupName="BulkTarget"/>
                    <ui:Button Grid.Column="3" Content="Select All" Margin="0,0,4,0" Padding="8,2"
                               Command="{Binding SelectAllPCsCommand}" Appearance="Secondary"/>
                    <ui:Button Grid.Column="4" Content="Deselect All" Padding="8,2"
                               Command="{Binding DeselectAllPCsCommand}" Appearance="Secondary"/>
                </Grid>

                <!-- Row 3: PC checkboxes (visible when not uploading to all) -->
                <ItemsControl Grid.Row="3" ItemsSource="{Binding PCs}" Margin="0,0,0,4"
                              Visibility="{Binding BulkUploadToAll, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Invert}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,16,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Hostname}"/>
                                    <TextBlock Text=" (" Foreground="Gray"/>
                                    <TextBlock Text="{Binding IPAddress}" Foreground="Gray"/>
                                    <TextBlock Text=")" Foreground="Gray"/>
                                </StackPanel>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Row 4: Pending files + progress -->
                <StackPanel Grid.Row="4">
                    <!-- File list -->
                    <ItemsControl ItemsSource="{Binding BulkPendingFiles}" Margin="0,0,0,4"
                                  MaxHeight="100"
                                  AllowDrop="True" Drop="BulkDropZone_Drop" DragOver="BulkDropZone_DragOver">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <Border BorderThickness="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        CornerRadius="4" Padding="6" MinHeight="36"
                                        AllowDrop="True" Drop="BulkDropZone_Drop" DragOver="BulkDropZone_DragOver">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <TextBlock Text="Drop files here or use 'Browse Files'"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Visibility="{Binding BulkPendingFiles.Count, Converter={StaticResource ZeroToVisibleConverter}, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                            <ItemsPresenter/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,1,0,1">
                                    <ui:Button DockPanel.Dock="Right" Content="✕" Padding="4,1" Margin="4,0,0,0"
                                               Appearance="Secondary"
                                               Command="{Binding DataContext.RemoveBulkFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Progress -->
                    <ProgressBar Height="6" Margin="0,2,0,0" Minimum="0" Maximum="100"
                                 Value="{Binding BulkProgress, Mode=OneWay}"
                                 Visibility="{Binding IsBulkUploading, Converter={StaticResource BoolToVisConverter}}"/>
                    <TextBlock Text="{Binding BulkStatusMessage}" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ STATUS BAR ═══ -->
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" Margin="0,8,0,0"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
    </Grid>
</UserControl>
