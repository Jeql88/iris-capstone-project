<UserControl x:Class="IRIS.UI.Views.Personnel.SoftwareManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:IRIS.UI.ViewModels"
             xmlns:converters="clr-namespace:IRIS.UI.Converters">
    
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="25,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
            <ui:SymbolIcon Symbol="AppsAddIn24" FontSize="32" Foreground="{StaticResource IRISPrimaryBrush}" Margin="0,0,12,0"/>
            <TextBlock Text="Software &amp; File Management" FontSize="32" FontWeight="Bold" 
                       Foreground="{StaticResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Section: Deploy/Uninstall -->
            <ui:Card Grid.Column="0">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Mode Toggle Buttons -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                        <ui:Button x:Name="DeployModeBtn" 
                                   Content="Deploy Software"
                                   Icon="{ui:SymbolIcon ArrowUpload24}"
                                   Click="DeployModeButton_Click"
                                   Appearance="Primary"
                                   Margin="0,0,10,0"/>
                        <ui:Button x:Name="UninstallModeBtn" 
                                   Content="Uninstall Software"
                                   Icon="{ui:SymbolIcon Delete24}"
                                   Click="UninstallModeButton_Click"
                                   Appearance="Secondary"/>
                    </StackPanel>

                    <!-- Deploy Mode Content -->
                    <StackPanel Grid.Row="1" x:Name="DeployModePanel">
                        <!-- Destination Path -->
                        <StackPanel Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <ui:SymbolIcon Symbol="Folder24" Foreground="{StaticResource IRISPrimaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Destination Path" FontWeight="Bold" FontSize="14" 
                                           Foreground="{StaticResource IRISPrimaryBrush}"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:TextBox Grid.Column="0" Text="{Binding DestinationPath}" 
                                           PlaceholderText="Select installation directory...">
                                    <ui:TextBox.Icon>
                                        <ui:SymbolIcon Symbol="FolderOpen24"/>
                                    </ui:TextBox.Icon>
                                </ui:TextBox>
                                <ui:Button Grid.Column="1" Icon="{ui:SymbolIcon FolderOpen24}"
                                           Command="{Binding BrowseDestinationCommand}"
                                           Appearance="Secondary" Margin="10,0,0,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- File Upload Area -->
                        <Border Height="250" CornerRadius="12" Margin="0,0,0,15"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{StaticResource IRISPrimaryBrush}"
                                BorderThickness="2" 
                                AllowDrop="True"
                                Drop="FileDropZone_Drop"
                                DragOver="FileDropZone_DragOver">
                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Width="80" Height="80" CornerRadius="40" 
                                            Background="{StaticResource IRISPrimaryBrush}" Margin="0,0,0,15"
                                            HorizontalAlignment="Center">
                                        <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="36" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="Drag &amp; Drop files here" FontSize="16" FontWeight="SemiBold" 
                                               HorizontalAlignment="Center" Margin="0,0,0,8" Foreground="#1a1a1a"/>
                                    <TextBlock Text="or" FontSize="14" 
                                               Foreground="#666666" 
                                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <ui:Button Content="Browse Files" 
                                               Icon="{ui:SymbolIcon Document24}"
                                               Command="{Binding BrowseFilesCommand}"
                                               Appearance="Primary"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Selected Files List -->
                        <StackPanel Visibility="{Binding HasSelectedFiles, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <ui:SymbolIcon Symbol="DocumentMultiple24" Foreground="{StaticResource IRISPrimaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Selected Files" FontWeight="Bold" FontSize="14" Foreground="#1a1a1a"/>
                                <ui:Badge Appearance="Primary" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding SelectedFilesCount}" FontSize="11"/>
                                </ui:Badge>
                            </StackPanel>
                            <ScrollViewer MaxHeight="100" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SelectedFiles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,5" Padding="10" CornerRadius="6"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:SymbolIcon Grid.Column="0" Symbol="Document24" Margin="0,0,10,0" 
                                                                   Foreground="{StaticResource IRISPrimaryBrush}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding FileName}" 
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="#1a1a1a"/>
                                                    <ui:Button Grid.Column="2" Icon="{ui:SymbolIcon Dismiss24}"
                                                               Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               CommandParameter="{Binding}"
                                                               Appearance="Secondary" BorderThickness="0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </StackPanel>

                    <!-- Uninstall Mode Content -->
                    <StackPanel Grid.Row="1" x:Name="UninstallModePanel" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <ui:SymbolIcon Symbol="Apps24" Foreground="{StaticResource IRISPrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Installed Applications" FontWeight="Bold" FontSize="14" 
                                       Foreground="{StaticResource IRISPrimaryBrush}"/>
                        </StackPanel>
                        
                        <ui:TextBox PlaceholderText="Search applications..."
                                   Text="{Binding ApplicationSearchText, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,0,15">
                            <ui:TextBox.Icon>
                                <ui:SymbolIcon Symbol="Search24"/>
                            </ui:TextBox.Icon>
                        </ui:TextBox>

                        <ScrollViewer MaxHeight="350" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredApplications}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Padding="12" CornerRadius="8" Cursor="Hand"
                                                MouseLeftButtonDown="AppItem_Click" Tag="{Binding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource IRISDarkBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource IRISPrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="45" Height="45" CornerRadius="8"
                                                        Background="{StaticResource IRISPrimaryBrush}" Margin="0,0,12,0">
                                                    <ui:SymbolIcon Symbol="Apps24" FontSize="20" Foreground="White"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="#1a1a1a"/>
                                                    <TextBlock Text="{Binding Version}" FontSize="12" 
                                                               Foreground="#666666"/>
                                                </StackPanel>
                                                <CheckBox Grid.Column="2" IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Action Button -->
                    <ui:Button Grid.Row="2" x:Name="ActionButton"
                               Content="Deploy to Selected PCs"
                               Icon="{ui:SymbolIcon Rocket24}"
                               Command="{Binding DeploySoftwareCommand}"
                               Appearance="Primary"
                               HorizontalAlignment="Right"
                               Height="45" FontSize="14" FontWeight="SemiBold"
                               Margin="0,20,0,0"/>
                </Grid>
            </ui:Card>

            <!-- Right Section: Target PCs -->
            <ui:Card Grid.Column="2">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <ui:SymbolIcon Symbol="Desktop24" Foreground="{StaticResource IRISPrimaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="Target PCs" FontWeight="Bold" FontSize="16" 
                                   Foreground="{StaticResource IRISPrimaryBrush}"/>
                    </StackPanel>

                    <!-- Room Selector -->
                    <ComboBox Grid.Row="1" ItemsSource="{Binding Rooms}"
                                SelectedItem="{Binding SelectedRoom}"
                                Margin="0,0,0,15">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Building24" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding RoomNumber}" Foreground="#1a1a1a"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- PC List -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredPCs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10" CornerRadius="8" Cursor="Hand"
                                            MouseLeftButtonDown="PCItem_Click" Tag="{Binding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource IRISDarkBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource IRISPrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6" Margin="0,0,10,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource OnlineStatusBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Offline">
                                                                <Setter Property="Background" Value="{StaticResource OfflineStatusBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <ui:SymbolIcon Symbol="Desktop24" FontSize="18" Foreground="White"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding PCName}" FontWeight="SemiBold" FontSize="13" Foreground="#1a1a1a"/>
                                                <TextBlock Text="{Binding IPAddress}" FontSize="11" 
                                                           Foreground="#666666"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Select All / Clear -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,15,0,0">
                        <ui:Button Content="Select All" 
                                   Icon="{ui:SymbolIcon CheckboxChecked24}"
                                   Command="{Binding SelectAllPCsCommand}"
                                   Appearance="Secondary" Margin="0,0,10,0"/>
                        <ui:Button Content="Clear" 
                                   Icon="{ui:SymbolIcon CheckboxUnchecked24}"
                                   Command="{Binding ClearSelectionCommand}"
                                   Appearance="Secondary"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </Grid>
    </Grid>
</UserControl>
