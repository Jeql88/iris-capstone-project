<UserControl x:Class="IRIS.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20" MaxWidth="800">
            <!-- Header -->
            <TextBlock Text="Settings" FontSize="36" FontWeight="Bold" 
                       Foreground="#8B0000" Margin="0,0,0,25"/>

            <!-- User Profile Card -->
            <Border Background="White" CornerRadius="8" Padding="25" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="User Profile" FontSize="20" FontWeight="Bold" 
                               Foreground="#DC143C" Margin="0,0,0,20"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Username:" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,15"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Username}" FontSize="14" Foreground="#666" Margin="0,0,0,15"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Full Name:" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,15"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FullName}" FontSize="14" Foreground="#666" Margin="0,0,0,15"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Role:" FontSize="14" FontWeight="SemiBold" Foreground="#333"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Role}" FontSize="14" Foreground="#666"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Change Password Card -->
            <Border Background="White" CornerRadius="8" Padding="25" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Change Password" FontSize="20" FontWeight="Bold" 
                               Foreground="#DC143C" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Current Password" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,15">
                        <PasswordBox x:Name="CurrentPasswordBox" Height="40" Padding="12,0" FontSize="14" 
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                    </Border>
                    
                    <TextBlock Text="New Password" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,15">
                        <PasswordBox x:Name="NewPasswordBox" Height="40" Padding="12,0" FontSize="14" 
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                    </Border>
                    
                    <TextBlock Text="Confirm New Password" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,20">
                        <PasswordBox x:Name="ConfirmPasswordBox" Height="40" Padding="12,0" FontSize="14" 
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                    </Border>
                    
                    <Button x:Name="ChangePasswordButton" Content="Change Password" Background="#DC143C" Foreground="White" 
                            Height="40" FontSize="14" FontWeight="SemiBold" 
                            BorderThickness="0" Cursor="Hand" Click="ChangePassword_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Logout Card -->
            <Border Background="White" CornerRadius="8" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Session" FontSize="20" FontWeight="Bold" 
                               Foreground="#DC143C" Margin="0,0,0,20"/>
                    
                    <Button x:Name="LogoutButton" Content="🚪 Logout" Background="White" Foreground="#DC143C" 
                            Height="40" FontSize="14" FontWeight="SemiBold" 
                            BorderThickness="1" BorderBrush="#DC143C" Cursor="Hand" Click="Logout_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
