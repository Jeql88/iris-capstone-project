<UserControl x:Class="IRIS.UI.Views.UsageMetricsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20">
            <!-- Header -->
            <Grid Margin="0,0,0,25">
                <TextBlock Text="Usage Metrics" FontSize="36" FontWeight="Bold" 
                           Foreground="#8B0000" VerticalAlignment="Center"/>
                
                <!-- Time Range Filter -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Time Range:" FontSize="14" Foreground="#333" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox SelectedValue="{Binding SelectedTimeRange, Mode=TwoWay}" 
                              SelectedValuePath="Content" Width="150" Height="35" FontSize="14"
                              Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Last 24 Hours"/>
                        <ComboBoxItem Content="Last 7 Days" IsSelected="True"/>
                        <ComboBoxItem Content="Last 30 Days"/>
                        <ComboBoxItem Content="Last 3 Months"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- Two Column Layout -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN: Most Used Applications -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="25">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Applications Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="📱 Most Used Applications" FontSize="20" FontWeight="Bold" 
                                       Foreground="#DC143C"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Showing " FontSize="13" Foreground="#DC143C"/>
                                <TextBlock Text="{Binding Applications.Count}" FontSize="13" 
                                           Foreground="#DC143C" FontWeight="SemiBold"/>
                                <TextBlock Text=" entries" FontSize="13" Foreground="#DC143C"/>
                            </StackPanel>
                        </Grid>

                        <!-- Applications DataGrid -->
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Applications}" 
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  Background="White" BorderThickness="0"
                                  RowBackground="White" AlternatingRowBackground="#FFF5F5"
                                  MinHeight="400" HorizontalGridLinesBrush="#F0F0F0"
                                  CanUserResizeColumns="True" RowHeight="45">
                            
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#333"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="12,12"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Foreground" Value="#333"/>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Application" Binding="{Binding Name}" Width="2*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Usage Count" Binding="{Binding UsageCount}" Width="1*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Usage %" Width="1.5*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <ProgressBar Value="{Binding Percentage}" Maximum="100" 
                                                             Height="20" Background="#F0F0F0" 
                                                             Foreground="#DC143C" BorderThickness="0"/>
                                                <TextBlock Text="{Binding Percentage, StringFormat={}{0:F1}%}" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Applications Pagination -->
                        <Grid Grid.Row="2" Margin="0,15,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="Rows per page:" FontSize="13" Foreground="#666" 
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox Width="60" Height="30" FontSize="12" SelectedIndex="1"
                                          VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="25"/>
                                    <ComboBoxItem Content="50"/>
                                </ComboBox>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="◀" Width="30" Height="30" FontSize="12" 
                                        Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                                        Margin="0,0,5,0"/>
                                <TextBlock Text="1 of 1" FontSize="13" Foreground="#666" 
                                           VerticalAlignment="Center" Margin="10,0"/>
                                <Button Content="▶" Width="30" Height="30" FontSize="12" 
                                        Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                                        Margin="5,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- RIGHT COLUMN: Most Visited Websites -->
                <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="25">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Websites Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="🌐 Most Visited Websites" FontSize="20" FontWeight="Bold" 
                                       Foreground="#DC143C"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Showing " FontSize="13" Foreground="#DC143C"/>
                                <TextBlock Text="{Binding Websites.Count}" FontSize="13" 
                                           Foreground="#DC143C" FontWeight="SemiBold"/>
                                <TextBlock Text=" entries" FontSize="13" Foreground="#DC143C"/>
                            </StackPanel>
                        </Grid>

                        <!-- Websites DataGrid -->
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Websites}" 
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  Background="White" BorderThickness="0"
                                  RowBackground="White" AlternatingRowBackground="#FFF5F5"
                                  MinHeight="400" HorizontalGridLinesBrush="#F0F0F0"
                                  CanUserResizeColumns="True" RowHeight="45">
                            
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#333"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="12,12"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Foreground" Value="#333"/>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Website" Binding="{Binding Domain}" Width="2*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Visit Count" Binding="{Binding VisitCount}" Width="1*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Visit %" Width="1.5*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <ProgressBar Value="{Binding Percentage}" Maximum="100" 
                                                             Height="20" Background="#F0F0F0" 
                                                             Foreground="#DC143C" BorderThickness="0"/>
                                                <TextBlock Text="{Binding Percentage, StringFormat={}{0:F1}%}" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Websites Pagination -->
                        <Grid Grid.Row="2" Margin="0,15,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="Rows per page:" FontSize="13" Foreground="#666" 
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox Width="60" Height="30" FontSize="12" SelectedIndex="1"
                                          VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                    <ComboBoxItem Content="5"/>
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="25"/>
                                    <ComboBoxItem Content="50"/>
                                </ComboBox>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="◀" Width="30" Height="30" FontSize="12" 
                                        Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                                        Margin="0,0,5,0"/>
                                <TextBlock Text="1 of 1" FontSize="13" Foreground="#666" 
                                           VerticalAlignment="Center" Margin="10,0"/>
                                <Button Content="▶" Width="30" Height="30" FontSize="12" 
                                        Background="White" BorderBrush="#E0E0E0" BorderThickness="1" 
                                        Margin="5,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>