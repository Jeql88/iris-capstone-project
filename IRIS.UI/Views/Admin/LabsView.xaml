<UserControl x:Class="IRIS.UI.Views.Admin.LabsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    
    <Grid>
        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25,20">
                <!-- Header -->
                <Grid Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ui:SymbolIcon Symbol="Building24" FontSize="32" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,12,0"/>
                        <TextBlock Text="Laboratories" FontSize="32" FontWeight="Bold" 
                                   Foreground="{DynamicResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ui:Button Content="Add New Laboratory" 
                               Command="{Binding OpenAddModalCommand}"
                               Icon="{ui:SymbolIcon Add24}"
                               Appearance="Primary"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Rooms Card -->
                <ui:Card Margin="0,0,0,20">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Table Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="BuildingMultiple24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Laboratories" FontSize="18" FontWeight="Bold" 
                                           Foreground="{DynamicResource IRISSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Show " FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <ComboBox SelectedValue="{Binding PageSize, Mode=TwoWay}" 
                                             ItemsSource="{Binding PageSizeOptions}"
                                             Width="70" Margin="0,0,5,0"/>
                                <TextBlock Text="entries" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Rooms List -->
                        <Grid Grid.Row="1" MinHeight="250">
                            <ListBox ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                        <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,8" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding RoomNumber}" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Capacity, StringFormat='Capacity: {0}'}" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <ui:Button Content="View PCs" 
                                                       Command="{Binding DataContext.ViewAssignedPCsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding Id}"
                                                       Icon="{ui:SymbolIcon Laptop24}"
                                                       Appearance="Secondary"
                                                       Padding="8,4"
                                                       Margin="0,0,12,0"/>
                                            <ui:Button Content="Edit" 
                                                       Command="{Binding DataContext.OpenEditModalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding}"
                                                       Icon="{ui:SymbolIcon Edit24}"
                                                       Appearance="Secondary"
                                                       Padding="8,4"
                                                       Margin="0,0,12,0"/>
                                            <ui:Button Content="Delete" 
                                                       Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       CommandParameter="{Binding}"
                                                       Icon="{ui:SymbolIcon Delete24}"
                                                       Appearance="Danger"
                                                       Padding="8,4"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="24,2"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#D6E9FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                            
                            <!-- Empty State -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Rooms.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ui:SymbolIcon Symbol="BuildingMultiple24" FontSize="48" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12"/>
                                <TextBlock Text="No laboratories found" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Add a new laboratory to get started" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                        <!-- Pagination Controls -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <ui:Button Command="{Binding PreviousPageCommand}" 
                                       Content="Previous" 
                                       Icon="{ui:SymbolIcon ChevronLeft24}"
                                       Appearance="Primary"
                                       Margin="0,0,10,0"/>
                            
                            <TextBlock Text="{Binding PageInfo}" FontSize="13" 
                                       VerticalAlignment="Center" Margin="15,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            
                            <ui:Button Command="{Binding NextPageCommand}" 
                                       Content="Next" 
                                       Icon="{ui:SymbolIcon ChevronRight24}"
                                       Appearance="Primary"
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- Add Laboratory Modal -->
        <Grid Background="#00000080" Visibility="{Binding IsAddModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:Card Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                    Width="500" 
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <ui:SymbolIcon Symbol="Add24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="Add New Laboratory" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource IRISSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Room Number" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ui:TextBox Text="{Binding AddRoomNumber, UpdateSourceTrigger=PropertyChanged}" 
                                    PlaceholderText="Enter room number"
                                    Icon="{ui:SymbolIcon Settings24}"
                                    Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Description" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ui:TextBox Text="{Binding AddDescription, UpdateSourceTrigger=PropertyChanged}" 
                                    PlaceholderText="Enter description"
                                    Icon="{ui:SymbolIcon Settings24}"
                                    Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Capacity" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ui:TextBox Text="{Binding AddCapacityText, UpdateSourceTrigger=PropertyChanged}" 
                                    PlaceholderText="Enter capacity"
                                    Icon="{ui:SymbolIcon Settings24}"
                                    Margin="0,0,0,15"/>
                        
                        <CheckBox Content="Active" IsChecked="{Binding AddIsActive}" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                        <ui:Button Content="Cancel" 
                                   Command="{Binding CloseAddModalCommand}"
                                   Icon="{ui:SymbolIcon Dismiss24}"
                                   Appearance="Secondary"
                                   Margin="0,0,10,0"/>
                        <ui:Button Content="Add Laboratory" 
                                   Command="{Binding CreateCommand}"
                                   Icon="{ui:SymbolIcon Add24}"
                                   Appearance="Primary"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </Grid>

        <!-- Edit Laboratory Modal -->
        <Grid Background="#00000080" Visibility="{Binding IsEditModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:Card Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                    Width="800" 
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <ui:SymbolIcon Symbol="Edit24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="Edit Laboratory" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource IRISSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Room Number" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ui:TextBox Text="{Binding RoomNumber, UpdateSourceTrigger=PropertyChanged}" 
                                    PlaceholderText="Enter room number"
                                    Icon="{ui:SymbolIcon Settings24}"
                                    Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Description" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ui:TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                                    PlaceholderText="Enter description"
                                    Icon="{ui:SymbolIcon Settings24}"
                                    Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Capacity" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ui:TextBox Text="{Binding CapacityText, UpdateSourceTrigger=PropertyChanged}" 
                                    PlaceholderText="Enter capacity"
                                    Icon="{ui:SymbolIcon Settings24}"
                                    Margin="0,0,0,15"/>
                        
                        <CheckBox Content="Active" IsChecked="{Binding IsActive}" Margin="0,0,0,15" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12" Margin="0,0,0,15">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#0B6A0B"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                            <Setter Property="Foreground" Value="#B00020"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,20,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ui:Button Content="Cancel" 
                                       Command="{Binding CloseEditModalCommand}"
                                       Icon="{ui:SymbolIcon Dismiss24}"
                                       Appearance="Secondary"
                                       Margin="0,0,10,0"/>
                            <ui:Button Content="Update" 
                                       Command="{Binding UpdateCommand}"
                                       Icon="{ui:SymbolIcon Edit24}"
                                       Appearance="Primary"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </Grid>

        <!-- Assigned PCs Modal -->
        <Grid Background="#00000080" Visibility="{Binding IsAssignedPCsModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:Card Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                    Width="800" 
                    Height="600"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Laptop24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Manage Laboratory PCs" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource IRISSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ModalRoomNumber, StringFormat='Room: {0}'}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Tab Control -->
                    <TabControl Grid.Row="1" Grid.RowSpan="2" Margin="0,0,0,20" x:Name="PCsTabControl" SelectedIndex="{Binding SelectedPCsTabIndex}">
                        <!-- Assigned PCs Tab -->
                        <TabItem Header="Assigned PCs" x:Name="AssignedPCsTab">
                            <Grid Margin="0,10,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding AssignedPCs}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Hostname}" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding MacAddress}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                
                                <!-- Empty State -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AssignedPCs.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <ui:SymbolIcon Symbol="Laptop24" FontSize="48" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12"/>
                                    <TextBlock Text="No PCs assigned" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="This laboratory has no assigned PCs" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <!-- Unassigned PCs Tab -->
                        <TabItem Header="Unassigned PCs" x:Name="UnassignedPCsTab">
                            <Grid Margin="0,10,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding UnassignedPCs}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Hostname}" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding MacAddress}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                
                                <!-- Empty State -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UnassignedPCs.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <ui:SymbolIcon Symbol="Laptop24" FontSize="48" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12"/>
                                    <TextBlock Text="No unassigned PCs" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="All PCs are assigned to laboratories" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                        <ui:Button Content="Assign Selected" 
                                   Command="{Binding AssignPCsToModalRoomCommand}"
                                   Icon="{ui:SymbolIcon Add24}"
                                   Appearance="Primary"
                                   Margin="0,0,10,0">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, ElementName=UnassignedPCsTab}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                        <ui:Button Content="Unassign Selected" 
                                   Command="{Binding UnassignCommand}"
                                   Icon="{ui:SymbolIcon Delete24}"
                                   Appearance="Secondary"
                                   Margin="0,0,10,0">
                            <ui:Button.Style>
                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected, ElementName=AssignedPCsTab}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:Button.Style>
                        </ui:Button>
                        <ui:Button Content="Close" 
                                   Click="CloseModal_Click"
                                   Icon="{ui:SymbolIcon Dismiss24}"
                                   Appearance="Secondary"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </Grid>
    </Grid>
</UserControl>
