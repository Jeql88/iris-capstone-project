<UserControl x:Class="IRIS.UI.Views.Admin.LabsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Rooms and Unassigned PCs Section -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25,20">
                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                    <ui:SymbolIcon Symbol="Building24" FontSize="32" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,12,0"/>
                    <TextBlock Text="Laboratories" FontSize="32" FontWeight="Bold" 
                               Foreground="{DynamicResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Rooms Card -->
                <ui:Card Margin="0,0,0,20">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Table Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                            <ui:SymbolIcon Symbol="BuildingMultiple24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Rooms" FontSize="18" FontWeight="Bold" 
                                       Foreground="{DynamicResource IRISSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Rooms List -->
                        <ListBox Grid.Row="1" ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom}" 
                                 MinHeight="250" MouseDown="ListBox_MouseDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" Margin="0,8">
                                        <TextBlock Text="{Binding RoomNumber}" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{Binding Capacity, StringFormat='Capacity: {0}'}" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="Margin" Value="0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#D6E9FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </ui:Card>

                <!-- Unassigned PCs Card -->
                <ui:Card>
                    <StackPanel Margin="15">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <ui:SymbolIcon Symbol="Laptop24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Unassigned PCs" FontSize="18" FontWeight="Bold" 
                                       Foreground="{DynamicResource IRISSecondaryBrush}"/>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding UnassignedPCs}" MinHeight="150">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Hostname}" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <TextBlock Text="{Binding MacAddress}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT: Add/Manage Laboratory Sidebar -->
        <Border Grid.Column="1" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                CornerRadius="12,0,0,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Add New Laboratory Section -->
                    <ui:Card Margin="0,0,0,20">
                        <StackPanel Margin="15">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <ui:SymbolIcon Symbol="Add24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Add New Laboratory" FontSize="18" FontWeight="Bold" 
                                           Foreground="{DynamicResource IRISSecondaryBrush}"/>
                            </StackPanel>
                            
                            <TextBlock Text="Room Number" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:TextBox Text="{Binding AddRoomNumber, UpdateSourceTrigger=PropertyChanged}" 
                                        PlaceholderText="Enter room number"
                                        Icon="{ui:SymbolIcon Settings24}"
                                        Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Description" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:TextBox Text="{Binding AddDescription, UpdateSourceTrigger=PropertyChanged}" 
                                        PlaceholderText="Enter description"
                                        Icon="{ui:SymbolIcon Settings24}"
                                        Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Capacity" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:TextBox Text="{Binding AddCapacityText, UpdateSourceTrigger=PropertyChanged}" 
                                        PlaceholderText="Enter capacity"
                                        Icon="{ui:SymbolIcon Settings24}"
                                        Margin="0,0,0,15"/>
                            
                            <CheckBox Content="Active" IsChecked="{Binding AddIsActive}" Margin="0,0,0,20" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            
                            <ui:Button Content="Add New Laboratory" 
                                       Command="{Binding CreateCommand}"
                                       Icon="{ui:SymbolIcon Add24}"
                                       Appearance="Primary"
                                       HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </ui:Card>

                    <!-- Manage Laboratory Section -->
                    <ui:Card>
                        <StackPanel Margin="15">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <ui:SymbolIcon Symbol="Edit24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Manage Laboratory" FontSize="18" FontWeight="Bold" 
                                           Foreground="{DynamicResource IRISSecondaryBrush}"/>
                            </StackPanel>
                            
                            <TextBlock Text="Room Number" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:TextBox Text="{Binding RoomNumber, UpdateSourceTrigger=PropertyChanged}" 
                                        PlaceholderText="Select a room..."
                                        Icon="{ui:SymbolIcon Settings24}"
                                        Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Description" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" 
                                        PlaceholderText="Select a room..."
                                        Icon="{ui:SymbolIcon Settings24}"
                                        Margin="0,0,0,15"/>
                            
                            <TextBlock Text="Capacity" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:TextBox Text="{Binding CapacityText, UpdateSourceTrigger=PropertyChanged}" 
                                        PlaceholderText="Select a room..."
                                        Icon="{ui:SymbolIcon Settings24}"
                                        Margin="0,0,0,15"/>
                            
                            <CheckBox Content="Active" IsChecked="{Binding IsActive}" Margin="0,0,0,20" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            
                            <TextBlock Margin="0,0,0,15" Text="{Binding StatusMessage}" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#0B6A0B"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                                <Setter Property="Foreground" Value="#B00020"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            
                            <ui:Button Content="Update" 
                                       Command="{Binding UpdateCommand}"
                                       Icon="{ui:SymbolIcon Edit24}"
                                       Appearance="Secondary"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,0,10"/>
                            
                            <ui:Button Content="Delete" 
                                       Command="{Binding DeleteCommand}"
                                       Icon="{ui:SymbolIcon Delete24}"
                                       Appearance="Danger"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,0,10"/>
                            
                            <ui:Button Content="Assign PCs" 
                                       Command="{Binding AssignCommand}"
                                       Icon="{ui:SymbolIcon Laptop24}"
                                       Appearance="Secondary"
                                       HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </ui:Card>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
