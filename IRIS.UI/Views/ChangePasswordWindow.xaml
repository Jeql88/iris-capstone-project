<Window x:Class="IRIS.UI.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password Required" Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="600" MinWidth="500"
        Background="#F5F5F5">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Border Background="White" CornerRadius="8" Margin="30" Padding="40">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.2" Color="#000000"/>
            </Border.Effect>
            
            <StackPanel>
                <TextBlock Text="⚠️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                
                <TextBlock Text="Password Change Required" FontSize="24" FontWeight="Bold" 
                           Foreground="#DC143C" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                
                <TextBlock Text="You must change your password before continuing." 
                           FontSize="14" Foreground="#666" HorizontalAlignment="Center" 
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,30"/>
                
                <TextBlock Text="Current Password" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,15">
                    <PasswordBox x:Name="CurrentPasswordBox" Height="40" Padding="12,0" FontSize="14" 
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"/>
                </Border>
                
                <TextBlock Text="New Password" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,15">
                    <PasswordBox x:Name="NewPasswordBox" Height="40" Padding="12,0" FontSize="14" 
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"/>
                </Border>
                
                <TextBlock Text="Confirm New Password" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White" Margin="0,0,0,25">
                    <PasswordBox x:Name="ConfirmPasswordBox" Height="40" Padding="12,0" FontSize="14" 
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"/>
                </Border>
                
                <Button x:Name="ChangePasswordButton" Content="Change Password" Background="#DC143C" Foreground="White" 
                        Height="45" FontSize="14" FontWeight="SemiBold" 
                        BorderThickness="0" Cursor="Hand" Click="ChangePassword_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
