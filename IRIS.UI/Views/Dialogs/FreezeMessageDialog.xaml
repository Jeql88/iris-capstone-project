<Window x:Class="IRIS.UI.Views.Dialogs.FreezeMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Freeze PC"
        Width="560"
        MinHeight="300"
        MaxHeight="600"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <ui:SymbolIcon Symbol="LockClosed24" FontSize="28" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,10,0"/>
            <TextBlock x:Name="TitleTextBlock" Text="Freeze PC" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock x:Name="MessageTextBlock" Grid.Row="1" Text="Enter the message shown on the student screen:" TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,10"/>

        <ui:TextBox x:Name="FreezeMessageTextBox"
                    Grid.Row="2"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    MinHeight="110"
                    VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <ui:Button x:Name="ConfirmButton" Content="Confirm" Width="100" Margin="0,0,8,0" Click="ConfirmButton_Click"
                       Appearance="Primary" Icon="{ui:SymbolIcon Checkmark24}" Cursor="Hand"/>
            <ui:Button x:Name="CancelButton" Content="Cancel" Width="100" Click="CancelButton_Click"
                       Appearance="Secondary" Icon="{ui:SymbolIcon Dismiss24}" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>