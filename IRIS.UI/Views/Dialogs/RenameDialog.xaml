<Window x:Class="IRIS.UI.Views.Dialogs.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Rename"
        Width="520"
        SizeToContent="Height"
        MinHeight="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <ui:SymbolIcon Symbol="Rename24" FontSize="32" Foreground="#F7630C" Margin="0,0,12,0"/>
            <TextBlock Text="Rename" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="Enter new name:" FontSize="14" Margin="0,0,0,8"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <ui:TextBox x:Name="NameTextBox"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
            <ui:Button Content="Rename" MinWidth="100" Margin="0,0,8,0" Click="OkButton_Click"
                       Appearance="Primary" Icon="{ui:SymbolIcon Checkmark24}" IsDefault="True" Cursor="Hand"/>
            <ui:Button Content="Cancel" MinWidth="100" Click="CancelButton_Click"
                       Appearance="Secondary" Icon="{ui:SymbolIcon Dismiss24}" IsCancel="True" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
