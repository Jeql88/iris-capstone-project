<Window x:Class="IRIS.UI.Views.Dialogs.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Confirm Action"
        Width="450" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <ui:SymbolIcon x:Name="IconSymbol" Symbol="Warning24" FontSize="32" Foreground="#F7630C" Margin="0,0,12,0"/>
            <TextBlock x:Name="TitleTextBlock" Text="Confirm Action" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Row="1" x:Name="MessageTextBlock" Text="Are you sure you want to proceed?" 
                   TextWrapping="Wrap" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <ui:Button Content="Confirm" Width="100" Margin="0,0,8,0" Click="ConfirmButton_Click" 
                       Appearance="Primary" Icon="{ui:SymbolIcon Checkmark24}"/>
            <ui:Button Content="Cancel" Width="100" Click="CancelButton_Click" 
                       Appearance="Secondary" Icon="{ui:SymbolIcon Dismiss24}"/>
        </StackPanel>
    </Grid>
</Window>
