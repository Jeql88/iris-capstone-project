<UserControl x:Class="IRIS.UI.Views.ViewScreenPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="View Screen" FontSize="32" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,10"/>
            <Button Command="{Binding BackCommand}" Background="Transparent" BorderThickness="0" 
                    HorizontalAlignment="Left" Padding="0" Cursor="Hand">
                <TextBlock Text="← Back to Tiled-View" FontSize="14" Foreground="#EF4444" FontWeight="SemiBold"/>
            </Button>
        </StackPanel>

        <!-- Screen Display -->
        <Border Grid.Row="1" Background="#1E3A5F" CornerRadius="8" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="Gray" Direction="270" ShadowDepth="2" Opacity="0.2" BlurRadius="5"/>
            </Border.Effect>
            <Image x:Name="ScreenImage" Stretch="Uniform"/>
        </Border>

        <!-- PC Info and Controls -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- PC Name and Status -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="{Binding PCName}" FontSize="24" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,10,0"/>
                <TextBlock Text="{Binding PCNumber}" FontSize="18" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Ellipse Width="10" Height="10" Fill="#10B981" VerticalAlignment="Center"/>
                <TextBlock Text="Viewing" FontSize="14" Foreground="#6B7280" VerticalAlignment="Center" Margin="150,0,0,0" HorizontalAlignment="Right"/>
            </StackPanel>

            <!-- Expandable Details Section -->
            <StackPanel Grid.Row="1">
                <!-- View Details Button -->
                <Button Command="{Binding ToggleDetailsCommand}" Background="Transparent" 
                        BorderThickness="0" HorizontalAlignment="Left" Padding="0" Cursor="Hand" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ExpandIcon}" FontSize="12" Foreground="#EF4444" Margin="0,0,5,0"/>
                        <TextBlock Text="View details" FontSize="14" Foreground="#EF4444" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <!-- Details Panel (Initially Collapsed) -->
                <Grid Visibility="{Binding DetailsVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: PC Information -->
                    <StackPanel Grid.Column="0">
                        <!-- Basic Info -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding IP}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Subnet Mask:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Subnet}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Network:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Network}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="OS:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding OS}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                        </Grid>

                        <!-- Real-time Metrics -->
                        <Grid Margin="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CPU}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU Temp:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CPUTemp}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="GPU Temp:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GPUTemp}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="RAM:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RAM}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                        </Grid>

                        <!-- Hardware Configuration -->
                        <TextBlock Text="Computer Hardware" FontSize="16" FontWeight="Bold" Foreground="#1F2937" Margin="0,15,0,10"/>
                        <StackPanel>
                            <TextBlock Text="{Binding CPUModel}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding GPUModel}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Motherboard}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding RAMModel}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding StoragePrimary}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding StorageSecondary}" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Right Column: Action Buttons -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="20,0,0,0">
                        <Border BorderBrush="#EF4444" BorderThickness="2" CornerRadius="6" Margin="0,0,0,10">
                            <Button Command="{Binding LockScreenCommand}" Background="Transparent" 
                                    BorderThickness="0" Height="45" Width="180" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔒" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Lock Screen" FontSize="14" Foreground="#EF4444" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <Border BorderBrush="#9CA3AF" BorderThickness="2" CornerRadius="6" Margin="0,0,0,10">
                            <Button Command="{Binding ShutDownCommand}" Background="Transparent" 
                                    BorderThickness="0" Height="45" Width="180" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏻" FontSize="16" Margin="0,0,8,0" Foreground="#9CA3AF"/>
                                    <TextBlock Text="Shut Down" FontSize="14" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <Border Background="#EF4444" CornerRadius="6">
                            <Button Command="{Binding RemoteDesktopCommand}" Background="Transparent" 
                                    BorderThickness="0" Height="45" Width="180" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🖥" FontSize="16" Margin="0,0,8,0" Foreground="White"/>
                                    <TextBlock Text="Remote Desktop" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
