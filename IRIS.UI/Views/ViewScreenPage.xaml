<UserControl x:Class="IRIS.UI.Views.ViewScreenPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="View Screen" FontSize="32" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,10"/>
            <Button x:Name="BackButton" Click="BackButton_Click" Background="Transparent" BorderThickness="0" 
                    HorizontalAlignment="Left" Padding="0" Cursor="Hand">
                <TextBlock Text="← Back to Tiled-View" FontSize="14" Foreground="#EF4444" FontWeight="SemiBold"/>
            </Button>
        </StackPanel>

        <!-- Screen Display -->
        <Border Grid.Row="1" Background="#1E3A5F" CornerRadius="8" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="Gray" Direction="270" ShadowDepth="2" Opacity="0.2" BlurRadius="5"/>
            </Border.Effect>
            <Image x:Name="ScreenImage" Stretch="Uniform"/>
        </Border>

        <!-- PC Info and Controls -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- PC Name and Status -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock x:Name="PCNameText" Text="LB448" FontSize="24" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,10,0"/>
                <TextBlock x:Name="PCNumberText" Text="PC12" FontSize="18" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Ellipse Width="10" Height="10" Fill="#10B981" VerticalAlignment="Center"/>
                <TextBlock x:Name="ViewingStatusText" Text="Viewing" FontSize="14" Foreground="#6B7280" VerticalAlignment="Center" Margin="150,0,0,0" HorizontalAlignment="Right"/>
            </StackPanel>

            <!-- Expandable Details Section -->
            <StackPanel Grid.Row="1">
                <!-- View Details Button -->
                <Button x:Name="ViewDetailsButton" Click="ViewDetailsButton_Click" Background="Transparent" 
                        BorderThickness="0" HorizontalAlignment="Left" Padding="0" Cursor="Hand" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ExpandIcon" Text="▼" FontSize="12" Foreground="#EF4444" Margin="0,0,5,0"/>
                        <TextBlock Text="View details" FontSize="14" Foreground="#EF4444" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <!-- Details Panel (Initially Collapsed) -->
                <Grid x:Name="DetailsPanel" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: PC Information -->
                    <StackPanel Grid.Column="0">
                        <!-- Basic Info -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="IPText" Text="192.168.1.102" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Subnet Mask:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SubnetText" Text="255.255.255.0" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Network:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="NetworkText" Text="32 Mbps" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="OS:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="OSText" Text="Windows 10 Pro" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                        </Grid>

                        <!-- Real-time Metrics -->
                        <Grid Margin="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CPUText" Text="74%" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU Temp:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CPUTempText" Text="63°C" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="GPU Temp:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GPUTempText" Text="44°C" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="RAM:" FontSize="14" Foreground="#6B7280" Margin="0,0,0,5"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="RAMText" Text="15%" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                        </Grid>

                        <!-- Hardware Configuration -->
                        <TextBlock Text="Computer Hardware" FontSize="16" FontWeight="Bold" Foreground="#1F2937" Margin="0,15,0,10"/>
                        <StackPanel>
                            <TextBlock x:Name="CPUModelText" Text="CPU: AMD Ryzen 9 7950X" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                            <TextBlock x:Name="GPUModelText" Text="GPU: NVIDIA RTX 4070 Super 12GB" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                            <TextBlock x:Name="MotherboardText" Text="Motherboard: ASUS ProArt X670E-Creator WiFi" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                            <TextBlock x:Name="RAMModelText" Text="RAM: Corsair Vengeance 64GB DDR5 5600MHz" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                            <TextBlock x:Name="StoragePrimaryText" Text="Storage (Primary): Samsung 990 PRO 2TB NVMe SSD" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                            <TextBlock x:Name="StorageSecondaryText" Text="Storage (Secondary): Seagate Barracuda 4TB HDD (7200 RPM)" FontSize="14" Foreground="#1F2937" Margin="0,0,0,5"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Right Column: Action Buttons -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="20,0,0,0">
                        <Border BorderBrush="#EF4444" BorderThickness="2" CornerRadius="6" Margin="0,0,0,10">
                            <Button x:Name="LockScreenButton" Click="LockScreenButton_Click" Background="Transparent" 
                                    BorderThickness="0" Height="45" Width="180" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔒" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Lock Screen" FontSize="14" Foreground="#EF4444" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <Border BorderBrush="#9CA3AF" BorderThickness="2" CornerRadius="6" Margin="0,0,0,10">
                            <Button x:Name="ShutDownButton" Click="ShutDownButton_Click" Background="Transparent" 
                                    BorderThickness="0" Height="45" Width="180" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⏻" FontSize="16" Margin="0,0,8,0" Foreground="#9CA3AF"/>
                                    <TextBlock Text="Shut Down" FontSize="14" Foreground="#9CA3AF" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <Border Background="#EF4444" CornerRadius="6">
                            <Button x:Name="RemoteDesktopButton" Click="RemoteDesktopButton_Click" Background="Transparent" 
                                    BorderThickness="0" Height="45" Width="180" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🖥" FontSize="16" Margin="0,0,8,0" Foreground="White"/>
                                    <TextBlock Text="Remote Desktop" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
