<UserControl x:Class="IRIS.UI.Views.PolicyEnforcementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:IRIS.UI.ViewModels"
             xmlns:converters="clr-namespace:IRIS.UI.Converters"
             Background="#F5F5F5">
    
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        
        <!-- Toggle Button Style -->
        <Style x:Key="PolicyToggleStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="#E5E7EB" CornerRadius="15" Width="50" Height="30">
                            <Ellipse x:Name="thumb" Width="22" Height="22" Fill="White" 
                                     HorizontalAlignment="Left" Margin="4,0,0,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#10B981"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,4,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Policy Enforcement" FontSize="36" FontWeight="Bold" 
                   Foreground="#8B0000" Margin="0,0,0,25"/>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Room Selection -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="Select Laboratory" FontSize="18" FontWeight="Bold" 
                               Foreground="#8B0000" Margin="0,0,0,20"/>

                    <!-- Room List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Rooms}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10" CornerRadius="8" Padding="15" Cursor="Hand"
                                            MouseLeftButtonDown="RoomBorder_Click" Tag="{Binding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F9FAFB"/>
                                                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#8B0000"/>
                                                        <Setter Property="BorderBrush" Value="#8B0000"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding RoomNumber}" FontWeight="Bold" FontSize="14">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#1F2937"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <Ellipse Width="6" Height="6" Margin="0,0,6,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#10B981"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding OnlineCount}" Value="0">
                                                                        <Setter Property="Fill" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Fill" Value="White"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding StatusText}" FontSize="11">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#6B7280"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Right Panel: Policy Controls -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,25">
                        <TextBlock Text="Policy Configuration" FontSize="20" FontWeight="Bold" 
                                   Foreground="#8B0000" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding SelectedRoomText}" FontSize="14" Foreground="#6B7280"/>
                    </StackPanel>

                    <!-- Policy Controls -->
                    <StackPanel Grid.Row="1" Visibility="{Binding HasSelectedRoom, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <!-- Current Settings Display -->
                        
                        <!-- Wallpaper Reset Policy -->
                        <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Wallpaper Reset on Start-up" FontWeight="Bold" 
                                               FontSize="18" Foreground="#8B0000" Margin="0,0,0,8"/>
                                    <TextBlock Text="Automatically resets desktop wallpaper to default when PCs start up." 
                                               FontSize="13" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    
                                    <!-- Wallpaper Upload Section -->
                                    <StackPanel Visibility="{Binding WallpaperResetEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Select Wallpaper Image:" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" BorderBrush="#D1D5DB" BorderThickness="1" Background="#F9FAFB" Padding="8">
                                                <TextBlock Text="{Binding SelectedWallpaperPath}" FontSize="12" Foreground="#666" 
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                            <Button Grid.Column="1" Command="{Binding BrowseWallpaperCommand}" 
                                                    Background="#8B0000" Foreground="White" BorderThickness="0" 
                                                    Padding="15,8" Margin="5,0,0,0" Cursor="Hand">
                                                <TextBlock Text="Browse" FontSize="12" FontWeight="SemiBold"/>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                                
                                <ToggleButton Grid.Column="1" Style="{StaticResource PolicyToggleStyle}"
                                              IsChecked="{Binding WallpaperResetEnabled}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Auto Shutdown Policy -->
                        <Border Background="White" CornerRadius="12" Padding="25">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.05"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="Auto Shutdown After Idle" FontWeight="Bold" 
                                               FontSize="18" Foreground="#8B0000" Margin="0,0,0,8"/>
                                    <TextBlock Text="Automatically shuts down PCs after specified idle time" 
                                               FontSize="13" Foreground="#666" TextWrapping="Wrap"/>
                                </StackPanel>
                                
                                <ToggleButton Grid.Row="0" Grid.Column="1" Style="{StaticResource PolicyToggleStyle}"
                                              IsChecked="{Binding AutoShutdownEnabled}" VerticalAlignment="Center"/>
                                
                                <!-- Idle Time Setting -->
                                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,20,0,0"
                                            Visibility="{Binding AutoShutdownEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Idle Time (minutes):" FontSize="14" Foreground="#666" Margin="0,0,0,8"/>
                                    <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Width="80" HorizontalAlignment="Left">
                                        <TextBox Text="{Binding AutoShutdownMinutes}" Padding="12,8" BorderThickness="0" Background="Transparent"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- No Room Selected Message -->
                    <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" 
                            CornerRadius="8" Padding="40" 
                            Visibility="{Binding HasSelectedRoom, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🏫" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="Select a Laboratory" FontSize="16" FontWeight="SemiBold" 
                                       Foreground="#374151" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="Choose a laboratory from the list to view and" FontSize="13" 
                                       Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <TextBlock Text="configure its policy settings" FontSize="13" 
                                       Foreground="#6B7280" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Action Button -->
                    <StackPanel Grid.Row="2" Margin="0,20,0,0"
                                Visibility="{Binding HasSelectedRoom, Converter={StaticResource BooleanToVisibilityConverter}}">
                        
                        <!-- Status Message -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" 
                                CornerRadius="6" Padding="12" Margin="0,0,0,15"
                                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                            <TextBlock Text="{Binding StatusMessage}" FontSize="13" 
                                       Foreground="{Binding StatusMessageColor}" FontWeight="SemiBold"/>
                        </Border>
                        
                        <Button Command="{Binding ApplyPoliciesCommand}" 
                                Background="#8B0000" BorderThickness="0" 
                                Padding="0,12" Cursor="Hand">
                            <TextBlock Text="Deploy to Selected Laboratory" FontSize="14" 
                                       Foreground="White" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
