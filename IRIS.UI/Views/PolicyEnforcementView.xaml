<UserControl x:Class="IRIS.UI.Views.PolicyEnforcementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:IRIS.UI.ViewModels"
             xmlns:converters="clr-namespace:IRIS.UI.Converters"
             Background="#F5F5F5">
    
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    
    <UserControl.DataContext>
        <vm:PolicyEnforcementViewModel/>
    </UserControl.DataContext>

    <Grid Margin="30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Policy Enforcement" FontSize="36" FontWeight="Bold" 
                   Foreground="#8B0000" Margin="0,0,0,25"/>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Policies List -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Policies" FontSize="20" FontWeight="Bold" 
                               Foreground="#D32F2F" Margin="0,0,0,15"/>
                    
                    <ListBox ItemsSource="{Binding Policies}" SelectedItem="{Binding SelectedPolicy}" 
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}" 
                                                    Padding="10" Margin="0,0,0,10" Cursor="Hand">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FFF5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" 
                                               FontSize="14" Foreground="#333" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding UpdatedAtText}" FontSize="12" 
                                               Foreground="#999" Margin="0,4,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Right Panel: Policy Details -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header with Edit/Delete buttons -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Policy Details" FontSize="20" FontWeight="Bold" 
                                   Foreground="#D32F2F" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding EditCommand}" Background="Transparent" 
                                    BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✏️" FontSize="16" Margin="0,0,5,0"/>
                                    <TextBlock Text="Edit" FontSize="14" Foreground="#D32F2F" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DeleteCommand}" Background="Transparent" 
                                    BorderThickness="0" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗑️" FontSize="16" Margin="0,0,5,0"/>
                                    <TextBlock Text="Delete" FontSize="14" Foreground="#D32F2F" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Policy Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Policy Name (Edit Mode) -->
                            <Border Background="#FFF3F3" BorderBrush="#E5E7EB" BorderThickness="1" 
                                    CornerRadius="6" Padding="12" Margin="0,0,0,15"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBox Text="{Binding SelectedPolicy.Name, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" FontSize="14"
                                         Foreground="#333"/>
                            </Border>

                            <!-- Script Content -->
                            <Border Background="#FFF3F3" BorderBrush="#E5E7EB" BorderThickness="1" 
                                    CornerRadius="6" Padding="15">
                                <TextBox Text="{Binding SelectedPolicy.ScriptContent, UpdateSourceTrigger=PropertyChanged}" 
                                         Background="Transparent" BorderThickness="0" 
                                         FontFamily="Consolas" FontSize="13" Foreground="#333"
                                         TextWrapping="Wrap" AcceptsReturn="True" 
                                         VerticalScrollBarVisibility="Auto" MinHeight="300"
                                         IsReadOnly="{Binding IsReadOnly}"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Lab Selection and Deploy (Edit Mode) -->
                    <StackPanel Grid.Row="2" Margin="0,20,0,0"
                                Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Select Target Laboratories" FontSize="16" FontWeight="Bold" 
                                   Foreground="#8B0000" Margin="0,0,0,15"/>
                        
                        <ItemsControl ItemsSource="{Binding Labs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,10,0" CornerRadius="8" Padding="20,15" Cursor="Hand"
                                            MouseLeftButtonDown="LabBorder_Click" Tag="{Binding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#830920"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#8B0000"/>
                                                        <Setter Property="BorderBrush" Value="#8B0000"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" 
                                                       TextAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#333"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                                <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#10B981"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding OnlineCount}" Value="0">
                                                                    <Setter Property="Fill" Value="#EF4444"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Fill" Value="White"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding StatusText}" FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Action Buttons -->
                        <Grid Margin="0,20,0,0">
                            <Button Command="{Binding ClearSelectionCommand}" 
                                    Background="Transparent" BorderThickness="0" 
                                    HorizontalAlignment="Left" Cursor="Hand">
                                <TextBlock Text="Clear Selection" FontSize="14" 
                                           Foreground="#D32F2F" FontWeight="SemiBold"/>
                            </Button>
                            <Border Background="#D32F2F" CornerRadius="6" 
                                    HorizontalAlignment="Right" Padding="0">
                                <Button Command="{Binding DeployCommand}" 
                                        Background="Transparent" Foreground="White" 
                                        BorderThickness="0" Padding="30,12" 
                                        FontSize="14" FontWeight="SemiBold" Cursor="Hand">
                                    <TextBlock Text="Deploy"/>
                                </Button>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
