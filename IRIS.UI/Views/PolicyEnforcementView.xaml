<UserControl x:Class="IRIS.UI.Views.PolicyEnforcementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:IRIS.UI.ViewModels"
             xmlns:converters="clr-namespace:IRIS.UI.Converters"
             Background="#F5F5F5">
    
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <!-- Toggle Button Style -->
        <Style x:Key="PolicyToggleStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="#E5E7EB" CornerRadius="15" Width="50" Height="30">
                            <Ellipse x:Name="thumb" Width="22" Height="22" Fill="White" 
                                     HorizontalAlignment="Left" Margin="4,0,0,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#10B981"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,4,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Policy Enforcement" FontSize="36" FontWeight="Bold" 
                   Foreground="#8B0000" Margin="0,0,0,25"/>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Policy Controls -->
            <StackPanel Grid.Column="0">
                <!-- Wallpaper Reset Policy -->
                <Border Background="White" CornerRadius="12" Padding="30" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Wallpaper Reset on Start-up" FontWeight="Bold" 
                                       FontSize="20" Foreground="#8B0000" Margin="0,0,0,8"/>
                            <TextBlock Text="Automatically resets desktop wallpaper to default when PCs start up." 
                                       FontSize="14" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            
                            <!-- Wallpaper Upload Section -->
                            <StackPanel Visibility="{Binding WallpaperResetEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Select Wallpaper Image:" FontSize="12" Foreground="#666" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" BorderBrush="#D1D5DB" BorderThickness="1" Background="#F9FAFB" Padding="8">
                                        <TextBlock Text="{Binding SelectedWallpaperPath}" FontSize="12" Foreground="#666" 
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <Button Grid.Column="1" Command="{Binding BrowseWallpaperCommand}" 
                                            Background="#8B0000" Foreground="White" BorderThickness="0" 
                                            Padding="15,8" Margin="5,0,0,0" Cursor="Hand">
                                        <TextBlock Text="Browse" FontSize="12" FontWeight="SemiBold"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                        
                        <ToggleButton Grid.Column="1" Style="{StaticResource PolicyToggleStyle}"
                                      IsChecked="{Binding WallpaperResetEnabled}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Auto Shutdown Policy -->
                <Border Background="White" CornerRadius="12" Padding="30">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Auto Shutdown After Idle" FontWeight="Bold" 
                                       FontSize="20" Foreground="#8B0000" Margin="0,0,0,8"/>
                            <TextBlock Text="Automatically shuts down PCs after specified idle time" 
                                       FontSize="14" Foreground="#666" TextWrapping="Wrap"/>
                        </StackPanel>
                        
                        <ToggleButton Grid.Row="0" Grid.Column="1" Style="{StaticResource PolicyToggleStyle}"
                                      IsChecked="{Binding AutoShutdownEnabled}" VerticalAlignment="Center"/>
                        
                        <!-- Idle Time Setting -->
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,20,0,0"
                                    Visibility="{Binding AutoShutdownEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Idle Time (minutes):" FontSize="14" Foreground="#666" Margin="0,0,0,8"/>
                            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Width="80" HorizontalAlignment="Left">
                                <TextBox Text="{Binding AutoShutdownMinutes}" Padding="12,8" BorderThickness="0" Background="Transparent"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Right Panel: Room Selection -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="Select Target Laboratories" FontSize="18" FontWeight="Bold" 
                               Foreground="#8B0000" Margin="0,0,0,20"/>

                    <!-- Room Grid -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Rooms}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" HorizontalAlignment="Stretch"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="5" CornerRadius="8" Padding="15" Cursor="Hand"
                                            MouseLeftButtonDown="RoomBorder_Click" Tag="{Binding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#8B0000"/>
                                                        <Setter Property="BorderBrush" Value="#8B0000"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding RoomNumber}" FontWeight="Bold" FontSize="16" 
                                                       TextAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#333"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                                <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#10B981"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding OnlineCount}" Value="0">
                                                                    <Setter Property="Fill" Value="#EF4444"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Fill" Value="White"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding StatusText}" FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Action Buttons -->
                    <Grid Grid.Row="2" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button Grid.Column="0" Command="{Binding ClearSelectionCommand}" 
                                Background="Transparent" BorderBrush="#EF4444" BorderThickness="2" 
                                Padding="0,10" Cursor="Hand">
                            <TextBlock Text="Clear Selection" FontSize="14" 
                                       Foreground="#EF4444" FontWeight="SemiBold"/>
                        </Button>
                        
                        <Button Grid.Column="2" Command="{Binding ApplyPoliciesCommand}" 
                                Background="#8B0000" BorderThickness="0" 
                                Padding="0,10" Cursor="Hand">
                            <TextBlock Text="Deploy" FontSize="14" 
                                       Foreground="White" FontWeight="SemiBold"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
