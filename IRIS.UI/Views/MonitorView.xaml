<UserControl x:Class="IRIS.UI.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    
    <UserControl.Resources>
        <!-- PC Card Style -->
        <Style x:Key="PCCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Gray" Direction="270" ShadowDepth="2" Opacity="0.2" BlurRadius="5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter Button Style -->
        <Style x:Key="FilterButtonStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>

        <!-- Status Colors -->
        <SolidColorBrush x:Key="OnlineColor" Color="#10B981"/>
        <SolidColorBrush x:Key="OfflineColor" Color="#EF4444"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F59E0B"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="Monitor" FontSize="32" FontWeight="Bold" Foreground="#1F2937"/>
            
            <ComboBox Grid.Column="1" Width="150" Height="40" VerticalAlignment="Center"
                      Background="#8B1538" Foreground="White" FontWeight="SemiBold">
                <ComboBoxItem Content="Archi Lab 1" IsSelected="True"/>
                <ComboBoxItem Content="Archi Lab 2"/>
                <ComboBoxItem Content="Archi Lab 3"/>
                <ComboBoxItem Content="Archi Lab 4"/>
            </ComboBox>
        </Grid>

        <!-- Current PC and Status Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Faculty PC Card -->
            <Border Grid.Column="0" Style="{StaticResource PCCardStyle}" BorderBrush="{StaticResource OnlineColor}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource OnlineColor}" VerticalAlignment="Center"/>
                        <TextBlock Text="Faculty PC" FontWeight="Bold" FontSize="16" Margin="8,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="IP: 192.168.1.101" FontSize="12" Foreground="#6B7280" Margin="0,2"/>
                    <TextBlock Text="OS: Windows 11" FontSize="12" Foreground="#6B7280" Margin="0,2"/>
                    <TextBlock Text="CPU: 45%" FontSize="12" Foreground="#6B7280" Margin="0,2"/>
                    <TextBlock Text="Network: 5.2 Mbps" FontSize="12" Foreground="#6B7280" Margin="0,2"/>
                    <TextBlock Text="RAM: 60%" FontSize="12" Foreground="#6B7280" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Status Cards -->
            <UniformGrid Grid.Column="1" Columns="3" Margin="20,0,0,0">
                <!-- Online -->
                <Border Style="{StaticResource PCCardStyle}" BorderBrush="{StaticResource OnlineColor}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Width="12" Height="12" Fill="{StaticResource OnlineColor}"/>
                            <TextBlock Text="Online" FontSize="14" Foreground="#6B7280" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="10" FontSize="32" FontWeight="Bold" Foreground="{StaticResource OnlineColor}"/>
                    </StackPanel>
                </Border>

                <!-- Offline -->
                <Border Style="{StaticResource PCCardStyle}" BorderBrush="{StaticResource OfflineColor}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Width="12" Height="12" Fill="{StaticResource OfflineColor}"/>
                            <TextBlock Text="Offline" FontSize="14" Foreground="#6B7280" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="3" FontSize="32" FontWeight="Bold" Foreground="{StaticResource OfflineColor}"/>
                    </StackPanel>
                </Border>

                <!-- Warning -->
                <Border Style="{StaticResource PCCardStyle}" BorderBrush="{StaticResource WarningColor}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Ellipse Width="12" Height="12" Fill="{StaticResource WarningColor}"/>
                            <TextBlock Text="Warning" FontSize="14" Foreground="#6B7280" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="3" FontSize="32" FontWeight="Bold" Foreground="{StaticResource WarningColor}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>

        <!-- Search and Filter Bar -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search Box -->
            <Border Grid.Column="0" Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" 
                    CornerRadius="6" Height="40" Margin="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔍" FontSize="16" Margin="12,0,8,0" 
                               VerticalAlignment="Center" Foreground="#9CA3AF"/>
                    <TextBox Grid.Column="1" Background="Transparent" BorderThickness="0" 
                             VerticalAlignment="Center" FontSize="14"
                             Text="Search PCs..." Foreground="#9CA3AF"/>
                </Grid>
            </Border>

            <!-- Filter Dropdown -->
            <Border Grid.Column="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" 
                    CornerRadius="6" Height="40" Margin="0,0,10,0">
                <ComboBox Style="{StaticResource FilterButtonStyle}" BorderThickness="0" Background="Transparent">
                    <ComboBoxItem IsSelected="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" Margin="0,0,8,0"/>
                            <TextBlock Text="All Status"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource OnlineColor}" Margin="0,0,8,0"/>
                            <TextBlock Text="Online"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource OfflineColor}" Margin="0,0,8,0"/>
                            <TextBlock Text="Offline"/>
                        </StackPanel>
                    </ComboBoxItem>
                    <ComboBoxItem>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource WarningColor}" Margin="0,0,8,0"/>
                            <TextBlock Text="Warning"/>
                        </StackPanel>
                    </ComboBoxItem>
                </ComboBox>
            </Border>

            <!-- Sort Dropdown -->
            <Border Grid.Column="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" 
                    CornerRadius="6" Height="40" Margin="0,0,10,0">
                <ComboBox Style="{StaticResource FilterButtonStyle}" BorderThickness="0" Background="Transparent">
                    <ComboBoxItem Content="Sort by Name" IsSelected="True"/>
                    <ComboBoxItem Content="Sort by Status"/>
                    <ComboBoxItem Content="Sort by IP"/>
                    <ComboBoxItem Content="Sort by CPU"/>
                    <ComboBoxItem Content="Sort by RAM"/>
                </ComboBox>
            </Border>

            <!-- View Screens Button -->
            <Border Grid.Column="3" Width="140" Height="40" Background="#EF4444" 
                    CornerRadius="6">
                <Button Background="Transparent" Foreground="White" BorderThickness="0" 
                        FontWeight="SemiBold" FontSize="14" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👁" Margin="0,0,8,0"/>
                        <TextBlock Text="View Screens"/>
                    </StackPanel>
                </Button>
            </Border>
        </Grid>

        <!-- PC Grid -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PCItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource PCCardStyle}" BorderBrush="{Binding StatusColor}">
                            <Grid>
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <Button x:Name="MenuButton" Content="⋮" FontSize="16" Foreground="#9CA3AF" 
                                                Background="Transparent" BorderThickness="0" Width="20" Height="20"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Click="MenuButton_Click" Cursor="Hand"/>
                                    </Grid>
                                    <TextBlock Text="{Binding IP}" FontSize="12" Foreground="#6B7280" Margin="0,2"/>
                                    <TextBlock Text="{Binding OS}" FontSize="12" Foreground="#6B7280" Margin="0,2"/>
                                    <TextBlock Text="{Binding CPU}" FontSize="12" Foreground="#6B7280" Margin="0,2"/>
                                    <TextBlock Text="{Binding Network}" FontSize="12" Foreground="#6B7280" Margin="0,2"/>
                                    <TextBlock Text="{Binding RAM}" FontSize="12" Foreground="#6B7280" Margin="0,2"/>
                                    <TextBlock Text="{Binding User}" FontSize="12" Foreground="#3B82F6" Margin="0,8,0,0"/>
                                </StackPanel>
                                
                                <!-- Context Menu Popup -->
                                <Popup x:Name="ContextMenuPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=MenuButton}"
                                       StaysOpen="False" AllowsTransparency="True">
                                    <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" 
                                            CornerRadius="6" Padding="8" Margin="5">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Gray" Direction="270" ShadowDepth="3" Opacity="0.3" BlurRadius="8"/>
                                        </Border.Effect>
                                        <StackPanel MinWidth="120">
                                            <Button Background="Transparent" BorderThickness="0" 
                                                    HorizontalAlignment="Stretch" Padding="8,6" Cursor="Hand"
                                                    Click="ViewScreen_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="👁" Margin="0,0,8,0"/>
                                                    <TextBlock Text="View Screen"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Background="Transparent" BorderThickness="0" 
                                                    HorizontalAlignment="Stretch" Padding="8,6" Cursor="Hand"
                                                    Click="LockScreen_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🔒" Margin="0,0,8,0"/>
                                                    <TextBlock Text="Lock Screen"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>