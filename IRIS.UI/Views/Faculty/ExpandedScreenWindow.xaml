<Window x:Class="IRIS.UI.Views.Faculty.ExpandedScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen View" WindowState="Maximized" WindowStyle="None"
        Background="Black"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1F1F1F" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding PCName}" FontSize="24" FontWeight="Bold" 
                           Foreground="White" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding RefreshScreenCommand}" 
                            Background="Transparent" BorderThickness="0" Padding="8"
                            Foreground="White" Margin="0,0,8,0" ToolTip="Refresh">
                        <TextBlock Text="🔄" FontSize="16"/>
                    </Button>
                    <Button Click="CloseButton_Click" 
                            Background="Transparent" BorderThickness="0" Padding="8"
                            Foreground="White" ToolTip="Close (ESC)">
                        <TextBlock Text="✕" FontSize="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Screen Image -->
        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Source="{Binding ScreenImage}" 
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   MaxWidth="1920" MaxHeight="1080"/>
        </Grid>
    </Grid>
</Window>
