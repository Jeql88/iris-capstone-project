<Window x:Class="IRIS.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IRIS.UI.Converters"
        mc:Ignorable="d"
        Title="IRIS - Login" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#8B1538">

    <Window.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style TargetType="TextBox" x:Key="InputStyle">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontFamily" Value="SF Pro"/>
        </Style>

        <Style TargetType="PasswordBox" x:Key="PasswordStyle">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontFamily" Value="SF Pro"/>
        </Style>

        <Style TargetType="Button" x:Key="LoginButtonStyle">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Background" Value="#FF4141"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CC3333"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#cccccc"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel - Background Image -->
        <Border Grid.Column="0">
            <Border.Background>
                <ImageBrush ImageSource="/IRIS.UI;component/assets/safad_login.png" Stretch="UniformToFill"/>
            </Border.Background>
        </Border>

        <!-- Right Panel - Login Form -->
        <Border Grid.Column="1" Background="#620F1E">
            <Grid Margin="50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Username Label -->
                <TextBlock Grid.Row="0" Text="Username" FontSize="16" FontWeight="Medium" Foreground="White" Margin="0,50,0,10" FontFamily="SF Pro"/>

                <!-- Username Input -->
                <TextBox Grid.Row="1" Style="{StaticResource InputStyle}" Margin="0,0,0,30"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Password Label -->
                <TextBlock Grid.Row="2" Text="Password" FontSize="16" FontWeight="Medium" Foreground="White" Margin="0,0,0,10" FontFamily="SF Pro"/>

                <!-- Password Input -->
                <PasswordBox Grid.Row="3" x:Name="PasswordBox" Style="{StaticResource PasswordStyle}" Margin="0,0,0,40"/>

                <!-- Error Message -->
                <TextBlock Grid.Row="4" Text="{Binding ErrorMessage}"
                          Foreground="#e74c3c" FontSize="14" Margin="0,0,0,20"
                          Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                          HorizontalAlignment="Center"/>

                <!-- Login Button -->
                <Button Grid.Row="5" Content="Login" Style="{StaticResource LoginButtonStyle}"
                        Command="{Binding LoginCommand}" HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.ColumnSpan="2" Background="#80000000" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="50" Height="50" Margin="0,0,0,10"/>
                <TextBlock Text="Logging in..." Foreground="White" FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>