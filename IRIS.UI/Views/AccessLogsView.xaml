<UserControl x:Class="IRIS.UI.Views.AccessLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20">
            <!-- Header -->
            <TextBlock Text="Access Logs" FontSize="36" FontWeight="Bold" 
                       Foreground="#8B0000" Margin="0,0,0,25"/>

            <!-- Search and Filters Card -->
            <Border Background="White" CornerRadius="8" Padding="25" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Filter Access Logs" FontSize="20" FontWeight="Bold" 
                               Foreground="#DC143C" Margin="0,0,0,20"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search Box -->
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="Search" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White">
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                         Height="40" Padding="12,0" FontSize="14" 
                                         BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Search by username, action, details, or IP address"/>
                            </Border>
                        </StackPanel>

                        <!-- Action Filter -->
                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                            <TextBlock Text="Action" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White">
                                <ComboBox SelectedValue="{Binding SelectedAction, Mode=TwoWay}" 
                                          SelectedValuePath="Content"
                                          Height="40" FontSize="14"
                                          BorderThickness="0" Background="Transparent" Padding="12,0"
                                          VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="All Actions" IsSelected="True"/>
                                    <ComboBoxItem Content="Login"/>
                                    <ComboBoxItem Content="Logout"/>
                                    <ComboBoxItem Content="Password Change"/>
                                    <ComboBoxItem Content="User Created"/>
                                    <ComboBoxItem Content="User Updated"/>
                                    <ComboBoxItem Content="User Deactivated"/>
                                    <ComboBoxItem Content="System Access"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>

                        <!-- Role Filter -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="User Role" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="White">
                                <ComboBox SelectedValue="{Binding SelectedRole, Mode=TwoWay}" 
                                          SelectedValuePath="Content"
                                          Height="40" FontSize="14"
                                          BorderThickness="0" Background="Transparent" Padding="12,0"
                                          VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="All Roles" IsSelected="True"/>
                                    <ComboBoxItem Content="System Administrator"/>
                                    <ComboBoxItem Content="IT Personnel"/>
                                    <ComboBoxItem Content="Faculty"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Access Logs Table Card -->
            <Border Background="White" CornerRadius="8" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Table Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="System Access Logs" FontSize="20" FontWeight="Bold" Foreground="#DC143C"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Show " FontSize="13" Foreground="#333" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox SelectedValue="{Binding PageSize, Mode=TwoWay}" 
                                      ItemsSource="{Binding PageSizeOptions}"
                                      Width="60" Height="30" FontSize="13"
                                      BorderThickness="1" BorderBrush="#E0E0E0" Padding="8,0"
                                      VerticalContentAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="entries" FontSize="13" Foreground="#333" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <TextBlock Text="{Binding PageInfo}" FontSize="13" Foreground="#DC143C" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding AccessLogs}" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              Background="White" BorderThickness="0"
                              RowBackground="White" AlternatingRowBackground="#FFF5F5"
                              MinHeight="400" HorizontalGridLinesBrush="#F0F0F0"
                              CanUserResizeColumns="True">
                        
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#333"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12,15"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Foreground" Value="#333"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="1.5*"/>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="1.2*"/>
                            <DataGridTextColumn Header="Role" Binding="{Binding UserRole}" Width="1.2*"/>
                            <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="1*"/>
                            <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="2*"/>
                            <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="1*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Pagination Controls -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Command="{Binding PreviousPageCommand}" Content="← Previous" 
                                Background="#DC143C" Foreground="White" 
                                Height="35" Padding="15,0" FontSize="13" FontWeight="SemiBold" 
                                BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPreviousPage}" Value="False">
                                            <Setter Property="Background" Value="#CCC"/>
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                        <TextBlock Text="{Binding PageInfo}" FontSize="13" Foreground="#333" 
                                   VerticalAlignment="Center" Margin="15,0"/>
                        
                        <Button Command="{Binding NextPageCommand}" Content="Next →" 
                                Background="#DC143C" Foreground="White" 
                                Height="35" Padding="15,0" FontSize="13" FontWeight="SemiBold" 
                                BorderThickness="0" Cursor="Hand" Margin="10,0,0,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasNextPage}" Value="False">
                                            <Setter Property="Background" Value="#CCC"/>
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>