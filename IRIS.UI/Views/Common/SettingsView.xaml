<UserControl x:Class="IRIS.UI.Views.Common.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20" MaxWidth="700">
            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                <ui:SymbolIcon Symbol="Settings24" FontSize="32" Foreground="{StaticResource IRISPrimaryBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="Settings" FontSize="32" FontWeight="Bold" 
                           Foreground="{StaticResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- User Profile Card -->
            <ui:Card Margin="0,0,0,20">
                <StackPanel Margin="15">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <ui:SymbolIcon Symbol="Person24" Foreground="{StaticResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="User Profile" FontSize="18" FontWeight="Bold" 
                                   Foreground="{StaticResource IRISSecondaryBrush}"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Username:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#1a1a1a"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Username}" FontSize="14" 
                                   Foreground="#666666" Margin="0,0,0,15"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Full Name:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#1a1a1a"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FullName}" FontSize="14" 
                                   Foreground="#666666" Margin="0,0,0,15"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Role:" FontSize="14" FontWeight="SemiBold" Foreground="#1a1a1a"/>
                        <ui:Badge Grid.Row="2" Grid.Column="1" Content="{Binding Role}" Appearance="Danger" HorizontalAlignment="Left"/>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!-- Change Password Card -->
            <ui:Card Margin="0,0,0,20">
                <StackPanel Margin="15">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <ui:SymbolIcon Symbol="Key24" Foreground="{StaticResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="Change Password" FontSize="18" FontWeight="Bold" 
                                   Foreground="{StaticResource IRISSecondaryBrush}"/>
                    </StackPanel>
                    
                    <TextBlock Text="Current Password" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#1a1a1a"/>
                    <ui:PasswordBox x:Name="CurrentPasswordBox" 
                                    PlaceholderText="Enter current password"
                                    Icon="{ui:SymbolIcon LockClosed24}"
                                    Margin="0,0,0,15"/>
                    
                    <TextBlock Text="New Password" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#1a1a1a"/>
                    <ui:PasswordBox x:Name="NewPasswordBox" 
                                    PlaceholderText="Enter new password"
                                    Icon="{ui:SymbolIcon Key24}"
                                    Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Confirm New Password" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#1a1a1a"/>
                    <ui:PasswordBox x:Name="ConfirmPasswordBox" 
                                    PlaceholderText="Confirm new password"
                                    Icon="{ui:SymbolIcon Checkmark24}"
                                    Margin="0,0,0,20"/>
                    
                    <ui:Button x:Name="ChangePasswordButton" 
                               Content="Change Password" 
                               Icon="{ui:SymbolIcon ArrowRight24}"
                               Appearance="Primary"
                               HorizontalAlignment="Stretch"
                               Click="ChangePassword_Click"/>
                </StackPanel>
            </ui:Card>

            <!-- Session Card -->
            <ui:Card>
                <StackPanel Margin="15">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <ui:SymbolIcon Symbol="SignOut24" Foreground="{StaticResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="Session" FontSize="18" FontWeight="Bold" 
                                   Foreground="{StaticResource IRISSecondaryBrush}"/>
                    </StackPanel>
                    
                    <ui:Button x:Name="LogoutButton" 
                               Content="Logout" 
                               Icon="{ui:SymbolIcon SignOut24}"
                               Appearance="Danger"
                               HorizontalAlignment="Stretch"
                               Click="Logout_Click"/>
                </StackPanel>
            </ui:Card>
        </StackPanel>
    </ScrollViewer>
</UserControl>
