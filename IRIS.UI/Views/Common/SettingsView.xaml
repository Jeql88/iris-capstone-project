<UserControl x:Class="IRIS.UI.Views.Common.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:IRIS.UI.Converters">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Branded button style for custom-colored buttons that need proper hover states -->
        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#B91C1C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#991B1B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BrandedLogoutButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#620F1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7A1326"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A0B17"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
        <StackPanel Margin="30,24,30,40" MaxWidth="760">

            <!-- ═══════════ Page Header ═══════════ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                <ui:SymbolIcon Symbol="Settings24" FontSize="28" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="Settings" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- ═══════════ User Profile ═══════════ -->
            <TextBlock Text="ACCOUNT" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Margin="2,0,0,8"/>

            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20,18" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Username" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Username, TargetNullValue='—'}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Full Name" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding FullName, TargetNullValue='—'}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Role" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    <Border Grid.Row="4" Grid.Column="2" HorizontalAlignment="Left"
                            Background="{DynamicResource IRISPrimaryBrush}" CornerRadius="4" Padding="10,3">
                        <TextBlock Text="{Binding Role, TargetNullValue='—'}" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════ Change Password ═══════════ -->
            <TextBlock Text="SECURITY" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Margin="2,20,0,8"/>

            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20,18" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <ui:SymbolIcon Symbol="ShieldKeyhole24" FontSize="18" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Change Password" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Current Password" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:PasswordBox x:Name="CurrentPasswordBox"
                                    PlaceholderText="Enter current password"
                                    Margin="0,0,0,14"/>

                    <TextBlock Text="New Password" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:PasswordBox x:Name="NewPasswordBox"
                                    PlaceholderText="Enter new password"
                                    Margin="0,0,0,14"/>

                    <TextBlock Text="Confirm New Password" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:PasswordBox x:Name="ConfirmPasswordBox"
                                    PlaceholderText="Confirm new password"
                                    Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding ChangePasswordStatusMessage}" FontSize="12" Margin="0,0,0,10" Foreground="#B00020" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ChangePasswordStatusMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ui:Button Content="Change Password"
                               Icon="{ui:SymbolIcon Checkmark24}"
                               Appearance="Primary"
                               HorizontalAlignment="Left"
                               Padding="16,8"
                               Click="ChangePassword_Click" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- ═══════════ Data Retention ═══════════ -->
                <TextBlock x:Name="DataRetentionHeader" Text="DATA RETENTION" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Margin="2,20,0,8"/>

                <Border x:Name="DataRetentionCard" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20,18" Margin="0,0,0,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <ui:SymbolIcon Symbol="Delete24" FontSize="18" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Automatic Cleanup" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Old monitoring data is automatically deleted daily. Configure retention periods below."
                               FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,18" TextWrapping="Wrap"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Hardware Metrics -->
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Hardware Metrics" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:NumberBox x:Name="HardwareRetentionBox" Grid.Column="0" Value="{Binding HardwareRetentionDays, Mode=OneWay}" Minimum="1" Maximum="365"
                                              SpinButtonPlacementMode="Compact"/>
                                <TextBlock Grid.Column="1" Text="days" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Network Metrics -->
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Network Metrics" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:NumberBox x:Name="NetworkRetentionBox" Grid.Column="0" Value="{Binding NetworkRetentionDays, Mode=OneWay}" Minimum="1" Maximum="365"
                                              SpinButtonPlacementMode="Compact"/>
                                <TextBlock Grid.Column="1" Text="days" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Alerts -->
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Alerts" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:NumberBox x:Name="AlertRetentionBox" Grid.Column="0" Value="{Binding AlertRetentionDays, Mode=OneWay}" Minimum="1" Maximum="730"
                                              SpinButtonPlacementMode="Compact"/>
                                <TextBlock Grid.Column="1" Text="days" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Website Usage -->
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Website Usage" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:NumberBox x:Name="WebsiteRetentionBox" Grid.Column="0" Value="{Binding WebsiteUsageRetentionDays, Mode=OneWay}" Minimum="1" Maximum="365"
                                              SpinButtonPlacementMode="Compact"/>
                                <TextBlock Grid.Column="1" Text="days" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Application Usage -->
                        <StackPanel Grid.Row="4" Grid.Column="0">
                            <TextBlock Text="Application Usage" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:NumberBox x:Name="SoftwareRetentionBox" Grid.Column="0" Value="{Binding SoftwareUsageRetentionDays, Mode=OneWay}" Minimum="1" Maximum="365"
                                              SpinButtonPlacementMode="Compact"/>
                                <TextBlock Grid.Column="1" Text="days" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Cleanup Hour -->
                        <StackPanel Grid.Row="4" Grid.Column="2">
                            <TextBlock Text="Daily Cleanup Hour (UTC)" FontSize="12" FontWeight="Medium" Margin="0,0,0,6"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:NumberBox x:Name="CleanupHourBox" Grid.Column="0" Value="{Binding CleanupHourUtc, Mode=OneWay}" Minimum="0" Maximum="23"
                                              SpinButtonPlacementMode="Compact"/>
                                <TextBlock Grid.Column="1" Text=":00" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding RetentionStatusMessage}" FontSize="12"
                               Margin="0,10,0,0" TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RetentionStatusMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsRetentionStatusError}" Value="True">
                                        <Setter Property="Foreground" Value="#B00020"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Status + Actions -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <ui:Button Content="Save Settings"
                                   Icon="{ui:SymbolIcon Save24}"
                                   Appearance="Primary"
                                   Padding="16,8"
                                   Click="SaveSettings_Click" Cursor="Hand"/>
                        <Button Content="Run Cleanup Now"
                               Style="{StaticResource DangerButtonStyle}"
                               Margin="10,0,0,0"
                               Click="RunCleanupNow_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══════════ Session ═══════════ -->
            <TextBlock Text="SESSION" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Margin="2,20,0,8"/>

            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="20,18" Margin="0,0,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="SignOut24" FontSize="18" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Sign Out" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="End your current session and return to the login screen."
                               FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,14" TextWrapping="Wrap"/>
                    <Button x:Name="LogoutButton"
                            Content="Logout"
                            HorizontalAlignment="Left"
                            Style="{StaticResource BrandedLogoutButtonStyle}"
                            Click="Logout_Click"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
