<UserControl x:Class="IRIS.UI.Views.Common.LoadingSpinner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Border Background="#80FFFFFF" x:Name="OverlayBorder" IsHitTestVisible="False">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <ui:ProgressRing IsIndeterminate="True" Width="36" Height="36"/>
            <TextBlock x:Name="LoadingTextBlock" Text="Loading..." Margin="0,8,0,0"
                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
