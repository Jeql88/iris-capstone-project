<UserControl x:Class="IRIS.UI.Views.Common.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:views="clr-namespace:IRIS.UI.Views.Common">

    <UserControl.Resources>
        <!-- Sidebar navigation button style that forces white text/icon -->
        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar Navigation -->
        <Border Grid.Column="0" CornerRadius="0,12,12,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#8B0000" Offset="0"/>
                    <GradientStop Color="#620F1E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="20,25,20,30">
                    <TextBlock Text="IRIS" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Resource Management" FontSize="11" Foreground="#CCAAAAAA" Margin="0,2,0,0"/>
                </StackPanel>
                
                <!-- Navigation Items -->
                <StackPanel Grid.Row="1" Margin="10,0">
                    <Button x:Name="DashboardBtn" Style="{StaticResource SidebarNavButtonStyle}" Click="DashboardBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Home24" FontSize="18" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Dashboard" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="MonitorBtn" Style="{StaticResource SidebarNavButtonStyle}" Click="MonitorBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Desktop24" FontSize="18" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Monitor" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="SoftwareManagementBtn" Style="{StaticResource SidebarNavButtonStyle}" Click="SoftwareManagementBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Apps24" FontSize="18" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Software Management" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="PolicyBtn" Style="{StaticResource SidebarNavButtonStyle}" Click="PolicyBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Shield24" FontSize="18" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Policy Enforcement" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="AccessLogsBtn" Style="{StaticResource SidebarNavButtonStyle}" Click="AccessLogsBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ClipboardTextLtr24" FontSize="18" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Access Logs" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="UserManagementBtn" Style="{StaticResource SidebarNavButtonStyle}" Click="UserManagementBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="People24" FontSize="18" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="User Management" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="UsageMetricsBtn" Style="{StaticResource SidebarNavButtonStyle}" Click="UsageMetricsBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DataUsage24" FontSize="18" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Usage Metrics" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="SettingsBtn" Style="{StaticResource SidebarNavButtonStyle}" Click="SettingsBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="18" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Settings" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Logout Button -->
                <StackPanel Grid.Row="2" Margin="10,10,10,20">
                    <Separator Margin="0,0,0,10" Background="#44FFFFFF"/>
                    <Button x:Name="LogoutBtn" Style="{StaticResource SidebarNavButtonStyle}" Click="LogoutBtn_Click"
                            Background="#CC0000">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="SignOut24" FontSize="18" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Logout" Foreground="White" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ContentControl x:Name="MainContent" Grid.Column="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="25,20">
                    <!-- Header with Lab Selector -->
                    <Grid Margin="0,0,0,25">
                        <TextBlock Text="Dashboard" FontSize="32" FontWeight="Bold" 
                                   Foreground="{DynamicResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
                        <ComboBox HorizontalAlignment="Right" Width="180" 
                                     SelectedItem="{Binding SelectedLab}">
                            <ComboBoxItem Content="Archi Lab 1" IsSelected="True" Foreground="#1a1a1a"/>
                            <ComboBoxItem Content="Archi Lab 2" Foreground="#1a1a1a"/>
                            <ComboBoxItem Content="Archi Lab 3" Foreground="#1a1a1a"/>
                            <ComboBoxItem Content="Archi Lab 4" Foreground="#1a1a1a"/>
                        </ComboBox>
                    </Grid>

                    <!-- Top Row: Latency and Network Performance -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Latency Card -->
                        <ui:Card Grid.Column="0">
                            <StackPanel Margin="15">
                                <Grid Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Pulse24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                                        <TextBlock Text="Latency (ms)" FontSize="18" FontWeight="Bold" 
                                                   Foreground="{DynamicResource IRISSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="Last 24 hours" FontSize="12" 
                                               Foreground="#666666" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="Average Latency (Today)" FontSize="14" 
                                               Foreground="#666666" 
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding AverageLatency, StringFormat={}{0:F0}ms}" 
                                               FontSize="28" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#1a1a1a"/>
                                </Grid>
                                <Border Height="180" Background="#f0f0f0" 
                                        CornerRadius="8">
                                    <TextBlock Text="[Latency Chart]" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               Foreground="#999999" 
                                               FontSize="14"/>
                                </Border>
                            </StackPanel>
                        </ui:Card>

                        <!-- Network Performance Card -->
                        <ui:Card Grid.Column="2">
                            <StackPanel Margin="15">
                                <Grid Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Wifi124" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                                        <TextBlock Text="Network Performance" FontSize="18" FontWeight="Bold" 
                                                   Foreground="{DynamicResource IRISSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="Last 24 hours" FontSize="12" 
                                               Foreground="#666666" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="Current Bandwidth Usage" FontSize="14" 
                                               Foreground="#666666"/>
                                    <TextBlock Text="{Binding CurrentBandwidth, StringFormat={}{0:F1} Mbps}" 
                                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#1a1a1a"/>
                                </Grid>
                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="Peak Usage (Today)" FontSize="14" 
                                               Foreground="#666666"/>
                                    <TextBlock Text="{Binding PeakBandwidth, StringFormat={}{0:F1} Mbps}" 
                                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#1a1a1a"/>
                                </Grid>
                                <Border Height="180" Background="#f0f0f0" 
                                        CornerRadius="8">
                                    <TextBlock Text="[Bandwidth Chart]" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               Foreground="#999999" 
                                               FontSize="14"/>
                                </Border>
                            </StackPanel>
                        </ui:Card>
                    </Grid>

                    <!-- Bottom Row: Packet Loss and Heavy Applications -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.9*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1.1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Packet Loss Card -->
                        <ui:Card Grid.Column="0">
                            <StackPanel Margin="15">
                                <Grid Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Warning24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                                        <TextBlock Text="Packet Loss %" FontSize="18" FontWeight="Bold" 
                                                   Foreground="{DynamicResource IRISSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="Last 24 hours" FontSize="12" 
                                               Foreground="#666666" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Border Height="220" Background="#f0f0f0" 
                                        CornerRadius="8">
                                    <TextBlock Text="[Packet Loss Chart]" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               Foreground="#999999" 
                                               FontSize="14"/>
                                </Border>
                            </StackPanel>
                        </ui:Card>

                        <!-- Heavy Applications Monitor Card -->
                        <ui:Card Grid.Column="2">
                            <StackPanel Margin="15">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <ui:SymbolIcon Symbol="AppsList24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Text="Heavy Applications Monitor" FontSize="18" FontWeight="Bold" 
                                               Foreground="{DynamicResource IRISSecondaryBrush}"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding HeavyApplications}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Padding="12" 
                                                    Background="#f0f0f0" 
                                                    CornerRadius="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="45"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="40" Height="40" 
                                                            Background="{DynamicResource IRISPrimaryBrush}" 
                                                            CornerRadius="8">
                                                        <TextBlock Text="{Binding Icon}" Foreground="White" 
                                                                   FontWeight="Bold" FontSize="14" 
                                                                   HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="#1a1a1a"/>
                                                        <TextBlock FontSize="12" 
                                                                   Foreground="#666666">
                                                            <Run Text="{Binding Instances}"/>
                                                            <Run Text="instances •"/>
                                                            <Run Text="{Binding RamUsage, StringFormat={}{0:F1}}"/>
                                                            <Run Text="GB RAM avg"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ui:Card>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </ContentControl>

        <!-- Right Sidebar: Active Lab PCs -->
        <Border Grid.Column="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                CornerRadius="12,0,0,12" Margin="0,10,0,10">
            <StackPanel Margin="20">
                <Grid Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DesktopPulse24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="Active Lab PCs" FontSize="18" FontWeight="Bold" Foreground="#1a1a1a"/>
                    </StackPanel>
                    <TextBlock FontSize="13" Foreground="#666666" 
                               HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Run Text="{Binding OnlinePCs}"/>
                        <Run Text="/"/>
                        <Run Text="{Binding TotalPCs}"/>
                        <Run Text="Online"/>
                    </TextBlock>
                </Grid>
                <ItemsControl ItemsSource="{Binding LabStatuses}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource IRISPrimaryBrush}" 
                                    CornerRadius="10" Padding="18,15" Margin="0,0,0,10">
                                <Grid>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" 
                                               FontSize="15" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ActivePCs}" FontSize="28" 
                                               FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
