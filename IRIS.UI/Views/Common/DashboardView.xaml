<UserControl x:Class="IRIS.UI.Views.Common.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:views="clr-namespace:IRIS.UI.Views.Common">
    
    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar Navigation -->
        <Border Grid.Column="0" CornerRadius="0,12,12,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#8B0000" Offset="0"/>
                    <GradientStop Color="#620F1E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="20,25,20,30">
                    <TextBlock Text="IRIS" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Resource Management" FontSize="11" Foreground="#CCCCCC" Margin="0,2,0,0"/>
                </StackPanel>
                
                <!-- Navigation Items -->
                <StackPanel Grid.Row="1" Margin="10,0">
                    <ui:Button x:Name="DashboardBtn" 
                              Content="Dashboard" 
                              Icon="{ui:SymbolIcon Home24}"
                              Appearance="Primary"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Margin="0,2"
                              Click="DashboardBtn_Click"/>
                    
                    <ui:Button x:Name="MonitorBtn" 
                              Content="Monitor" 
                              Icon="{ui:SymbolIcon Desktop24}"
                              Appearance="Secondary"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Margin="0,2"
                              Click="MonitorBtn_Click"/>
                    
                    <ui:Button x:Name="SoftwareManagementBtn" 
                              Content="Software Management" 
                              Icon="{ui:SymbolIcon Apps24}"
                              Appearance="Secondary"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Margin="0,2"
                              Click="SoftwareManagementBtn_Click"/>
                    
                    <ui:Button x:Name="PolicyBtn" 
                              Content="Policy Enforcement" 
                              Icon="{ui:SymbolIcon Shield24}"
                              Appearance="Secondary"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Margin="0,2"
                              Click="PolicyBtn_Click"/>
                    
                    <ui:Button x:Name="AccessLogsBtn" 
                              Content="Access Logs" 
                              Icon="{ui:SymbolIcon ClipboardTextLtr24}"
                              Appearance="Secondary"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Margin="0,2"
                              Click="AccessLogsBtn_Click"/>
                    
                    <ui:Button x:Name="UserManagementBtn" 
                              Content="User Management" 
                              Icon="{ui:SymbolIcon People24}"
                              Appearance="Secondary"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Margin="0,2"
                              Click="UserManagementBtn_Click"/>
                    
                    <ui:Button x:Name="UsageMetricsBtn" 
                              Content="Usage Metrics" 
                              Icon="{ui:SymbolIcon DataUsage24}"
                              Appearance="Secondary"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Margin="0,2"
                              Click="UsageMetricsBtn_Click"/>
                    
                    <ui:Button x:Name="SettingsBtn" 
                              Content="Settings" 
                              Icon="{ui:SymbolIcon Settings24}"
                              Appearance="Secondary"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Margin="0,2"
                              Click="SettingsBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ContentControl x:Name="MainContent" Grid.Column="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="25,20">
                    <!-- Header with Lab Selector -->
                    <Grid Margin="0,0,0,25">
                        <TextBlock Text="Dashboard" FontSize="32" FontWeight="Bold" 
                                   Foreground="{StaticResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
                        <ComboBox HorizontalAlignment="Right" Width="180" 
                                     SelectedItem="{Binding SelectedLab}">
                            <ComboBoxItem Content="Archi Lab 1" IsSelected="True"/>
                            <ComboBoxItem Content="Archi Lab 2"/>
                            <ComboBoxItem Content="Archi Lab 3"/>
                            <ComboBoxItem Content="Archi Lab 4"/>
                        </ComboBox>
                    </Grid>

                    <!-- Top Row: Latency and Network Performance -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Latency Card -->
                        <ui:Card Grid.Column="0">
                            <StackPanel Margin="5">
                                <Grid Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Pulse24" Foreground="{StaticResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                                        <TextBlock Text="Latency (ms)" FontSize="18" FontWeight="Bold" 
                                                   Foreground="{StaticResource IRISSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="Last 24 hours" FontSize="12" 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="Average Latency (Today)" FontSize="14" 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding AverageLatency, StringFormat={}{0:F0}ms}" 
                                               FontSize="28" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="180" Background="{DynamicResource ControlFillColorDefaultBrush}" 
                                        CornerRadius="8">
                                    <TextBlock Text="[Latency Chart]" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" 
                                               FontSize="14"/>
                                </Border>
                            </StackPanel>
                        </ui:Card>

                        <!-- Network Performance Card -->
                        <ui:Card Grid.Column="2">
                            <StackPanel Margin="5">
                                <Grid Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Wifi124" Foreground="{StaticResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                                        <TextBlock Text="Network Performance" FontSize="18" FontWeight="Bold" 
                                                   Foreground="{StaticResource IRISSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="Last 24 hours" FontSize="12" 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="Current Bandwidth Usage" FontSize="14" 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{Binding CurrentBandwidth, StringFormat={}{0:F1} Mbps}" 
                                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,20">
                                    <TextBlock Text="Peak Usage (Today)" FontSize="14" 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{Binding PeakBandwidth, StringFormat={}{0:F1} Mbps}" 
                                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Height="180" Background="{DynamicResource ControlFillColorDefaultBrush}" 
                                        CornerRadius="8">
                                    <TextBlock Text="[Bandwidth Chart]" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" 
                                               FontSize="14"/>
                                </Border>
                            </StackPanel>
                        </ui:Card>
                    </Grid>

                    <!-- Bottom Row: Packet Loss and Heavy Applications -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.9*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1.1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Packet Loss Card -->
                        <ui:Card Grid.Column="0">
                            <StackPanel Margin="5">
                                <Grid Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Warning24" Foreground="{StaticResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                                        <TextBlock Text="Packet Loss %" FontSize="18" FontWeight="Bold" 
                                                   Foreground="{StaticResource IRISSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="Last 24 hours" FontSize="12" 
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Border Height="220" Background="{DynamicResource ControlFillColorDefaultBrush}" 
                                        CornerRadius="8">
                                    <TextBlock Text="[Packet Loss Chart]" HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" 
                                               FontSize="14"/>
                                </Border>
                            </StackPanel>
                        </ui:Card>

                        <!-- Heavy Applications Monitor Card -->
                        <ui:Card Grid.Column="2">
                            <StackPanel Margin="5">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <ui:SymbolIcon Symbol="AppsList24" Foreground="{StaticResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Text="Heavy Applications Monitor" FontSize="18" FontWeight="Bold" 
                                               Foreground="{StaticResource IRISSecondaryBrush}"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding HeavyApplications}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Padding="12" 
                                                    Background="{DynamicResource ControlFillColorDefaultBrush}" 
                                                    CornerRadius="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="45"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="40" Height="40" 
                                                            Background="{StaticResource IRISPrimaryBrush}" 
                                                            CornerRadius="8">
                                                        <TextBlock Text="{Binding Icon}" Foreground="White" 
                                                                   FontWeight="Bold" FontSize="14" 
                                                                   HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                                        <TextBlock FontSize="12" 
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                            <Run Text="{Binding Instances}"/>
                                                            <Run Text="instances •"/>
                                                            <Run Text="{Binding RamUsage, StringFormat={}{0:F1}}"/>
                                                            <Run Text="GB RAM avg"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ui:Card>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </ContentControl>

        <!-- Right Sidebar: Active Lab PCs -->
        <Border Grid.Column="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                CornerRadius="12,0,0,12" Margin="0,10,0,10">
            <StackPanel Margin="20">
                <Grid Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DesktopPulse24" Foreground="{StaticResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="Active Lab PCs" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBlock FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                               HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Run Text="{Binding OnlinePCs}"/>
                        <Run Text="/"/>
                        <Run Text="{Binding TotalPCs}"/>
                        <Run Text="Online"/>
                    </TextBlock>
                </Grid>
                <ItemsControl ItemsSource="{Binding LabStatuses}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource IRISPrimaryBrush}" 
                                    CornerRadius="10" Padding="18,15" Margin="0,0,0,10">
                                <Grid>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" 
                                               FontSize="15" Foreground="White" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ActivePCs}" FontSize="28" 
                                               FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
