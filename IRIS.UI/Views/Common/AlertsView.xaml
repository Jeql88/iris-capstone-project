<UserControl x:Class="IRIS.UI.Views.Common.AlertsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:IRIS.UI.Converters"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Alert24" FontSize="24" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,10,0"/>
                    <TextBlock Text="Alerts" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
                <TextBlock Text="{Binding LastUpdatedText}" FontSize="12" Margin="34,4,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Icon="{ui:SymbolIcon Checkmark24}" Content="Acknowledge All Visible" Appearance="Secondary" Command="{Binding AcknowledgeVisibleCommand}" Margin="0,0,8,0"/>
                <ui:Button Icon="{ui:SymbolIcon CheckmarkCircle24}" Content="Resolve All Visible" Appearance="Secondary" Command="{Binding ResolveVisibleCommand}" Margin="0,0,8,0"/>
                <ui:Button Icon="{ui:SymbolIcon CheckmarkSquare24}" Content="Acknowledge Selected" Appearance="Secondary" Command="{Binding AcknowledgeCommand}" Margin="0,0,8,0"/>
                <ui:Button Icon="{ui:SymbolIcon CheckmarkCircle24}" Content="Resolve Selected" Appearance="Primary" Command="{Binding ResolveCommand}" Margin="0,0,8,0"/>
                <ui:Button Icon="{ui:SymbolIcon ArrowClockwise24}" Content="Refresh" Appearance="Secondary" Command="{Binding RefreshCommand}" Margin="0,0,8,0" ToolTip="Refresh alerts"/>
                <ui:Button Icon="{ui:SymbolIcon ArrowDownload24}" Content="Export CSV" Appearance="Secondary" Command="{Binding ExportCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Summary cards row -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total -->
            <ui:Card Grid.Column="0" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource ControlFillColorTertiaryBrush}" Margin="0,0,10,0">
                        <ui:SymbolIcon Symbol="Alert24" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Total" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding AlertCount}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Critical -->
            <ui:Card Grid.Column="2" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <SolidColorBrush Color="#16EF4444"/>
                        </Border.Background>
                        <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="16" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Critical" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding CriticalCount}" FontSize="22" FontWeight="Bold" Foreground="#EF4444"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- High -->
            <ui:Card Grid.Column="4" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <SolidColorBrush Color="#16F59E0B"/>
                        </Border.Background>
                        <ui:SymbolIcon Symbol="Warning24" FontSize="16" Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="High" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding HighCount}" FontSize="22" FontWeight="Bold" Foreground="#F59E0B"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Open -->
            <ui:Card Grid.Column="6" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <SolidColorBrush Color="#1610B981"/>
                        </Border.Background>
                        <ui:SymbolIcon Symbol="Clock24" FontSize="16" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Open" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding OpenCount}" FontSize="22" FontWeight="Bold" Foreground="#10B981"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </Grid>

        <!-- Filter bar -->
        <ui:Card Grid.Row="2" Padding="15" Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <ui:SymbolIcon Symbol="Filter24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="Filter Alerts" FontSize="18" FontWeight="Bold" 
                               Foreground="{DynamicResource IRISSecondaryBrush}"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Search" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#1a1a1a"/>
                        <ui:TextBox PlaceholderText="Search PC, room, or message..." Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                    Icon="{ui:SymbolIcon Search24}"/>
                    </StackPanel>

                    <!-- Severity -->
                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="Severity" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#1a1a1a"/>
                        <ComboBox ItemsSource="{Binding SeverityOptions}" SelectedItem="{Binding SeverityFilter}"/>
                    </StackPanel>

                    <!-- Type -->
                    <StackPanel Grid.Column="2" Margin="0,0,15,0">
                        <TextBlock Text="Type" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#1a1a1a"/>
                        <ComboBox ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding TypeFilter}"/>
                    </StackPanel>

                    <!-- State -->
                    <StackPanel Grid.Column="3" Margin="0,0,15,0">
                        <TextBlock Text="State" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#1a1a1a"/>
                        <ComboBox ItemsSource="{Binding StateOptions}" SelectedItem="{Binding StateFilter}"/>
                    </StackPanel>

                    <!-- Lab -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Lab" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#1a1a1a"/>
                        <ComboBox ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom}" DisplayMemberPath="RoomNumber"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ui:Card>

        <!-- Data grid -->
        <ui:Card Grid.Row="3">
            <Grid>
                <DataGrid ItemsSource="{Binding FilteredAlerts}"
                          SelectedItem="{Binding SelectedAlert}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          ColumnHeaderHeight="36"
                          RowHeight="34"
                              MinHeight="450"
                          Margin="8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="160"/>
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90"/>
                        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="100"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                        <DataGridTextColumn Header="PC" Binding="{Binding PCName}" Width="140"/>
                        <DataGridTextColumn Header="Room" Binding="{Binding RoomName}" Width="100"/>
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsLoading}" Value="False"/>
                                        <Condition Binding="{Binding AlertCount}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="36" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="No alerts match current filters" Margin="0,8,0,0" FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Try adjusting your filters or check back later" Margin="0,4,0,0" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>
