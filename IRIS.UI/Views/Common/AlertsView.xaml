<UserControl x:Class="IRIS.UI.Views.Common.AlertsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:IRIS.UI.Converters"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Flat column header with sort-direction arrow indicator.
             Fully overrides the WPF-UI default template (which uses gradient brushes) so the
             header paints as a solid surface with a thin divider instead of a glossy panel. -->
        <Style x:Key="SortableColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Grid>
                            <Border x:Name="HeaderBackground"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </Border>
                            <!-- Column-resize grippers must exist with these exact names for DataGrid behavior -->
                            <Thumb x:Name="PART_LeftHeaderGripper" HorizontalAlignment="Left" Width="4" Cursor="SizeWE" Opacity="0"/>
                            <Thumb x:Name="PART_RightHeaderGripper" HorizontalAlignment="Right" Width="4" Cursor="SizeWE" Opacity="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBackground" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SortArrow" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10"
                                       Foreground="{DynamicResource IRISPrimaryBrush}"/>
                        </StackPanel>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Path=SortDirection, RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}}" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Text" Value="&#x25B2;"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Path=SortDirection, RelativeSource={RelativeSource AncestorType=DataGridColumnHeader}}" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Text" Value="&#x25BC;"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Alert24" FontSize="32" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,12,0"/>
                    <TextBlock Text="Alerts" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding LastUpdatedText}" FontSize="12" Margin="0,4,0,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Action buttons moved next to System Alerts table header below -->
        </Grid>

        <!-- Summary cards row -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total -->
            <ui:Card Grid.Column="0" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource ControlFillColorTertiaryBrush}" Margin="0,0,10,0">
                        <ui:SymbolIcon Symbol="Alert24" FontSize="16" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Total" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding AlertCount}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Critical -->
            <ui:Card Grid.Column="2" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <SolidColorBrush Color="#16EF4444"/>
                        </Border.Background>
                        <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="16" Foreground="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Critical" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding CriticalCount}" FontSize="22" FontWeight="Bold" Foreground="#EF4444"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- High -->
            <ui:Card Grid.Column="4" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <SolidColorBrush Color="#16F59E0B"/>
                        </Border.Background>
                        <ui:SymbolIcon Symbol="Warning24" FontSize="16" Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="High" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding HighCount}" FontSize="22" FontWeight="Bold" Foreground="#F59E0B"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Open -->
            <ui:Card Grid.Column="6" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0">
                        <Border.Background>
                            <SolidColorBrush Color="#1610B981"/>
                        </Border.Background>
                        <ui:SymbolIcon Symbol="Clock24" FontSize="16" Foreground="#10B981" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Open" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="{Binding OpenCount}" FontSize="22" FontWeight="Bold" Foreground="#10B981"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </Grid>

        <!-- Filter bar -->
        <ui:Card Grid.Row="2" Padding="15" Margin="0,0,0,6">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <ui:SymbolIcon Symbol="Filter24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="Filter Alerts" FontSize="18" FontWeight="Bold" 
                               Foreground="{DynamicResource IRISSecondaryBrush}"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Search" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ui:TextBox PlaceholderText="Search PC, laboratory, or message..." Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                    Icon="{ui:SymbolIcon Search24}"/>
                    </StackPanel>

                    <!-- Severity -->
                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="Severity" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ComboBox ItemsSource="{Binding SeverityOptions}" SelectedItem="{Binding SeverityFilter}"/>
                    </StackPanel>

                    <!-- Type -->
                    <StackPanel Grid.Column="2" Margin="0,0,15,0">
                        <TextBlock Text="Type" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ComboBox ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding TypeFilter}"/>
                    </StackPanel>

                    <!-- State -->
                    <StackPanel Grid.Column="3" Margin="0,0,15,0">
                        <TextBlock Text="State" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ComboBox ItemsSource="{Binding StateOptions}" SelectedItem="{Binding StateFilter}"/>
                    </StackPanel>

                    <!-- Laboratory -->
                    <StackPanel Grid.Column="4" Margin="0,0,15,0">
                        <TextBlock Text="Laboratory" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ComboBox ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom}" DisplayMemberPath="RoomNumber"/>
                    </StackPanel>

                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <ui:Button Content="Apply Filters"
                               Command="{Binding ApplyFiltersCommand}"
                               Appearance="Primary"
                               Margin="0,0,10,0"/>
                    <ui:Button Content="Reset"
                               Command="{Binding ResetFiltersCommand}"
                               Appearance="Secondary"/>
                </StackPanel>
            </StackPanel>
        </ui:Card>

        <!-- Data grid with pagination -->
        <ui:Card Grid.Row="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Grid Grid.Row="0" Margin="12,12,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Alert24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="System Alerts" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource IRISSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Right side: action dropdowns + page size + export; uses WrapPanel so it flows at 125-150% DPI -->
                    <WrapPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ui:DropDownButton Icon="{ui:SymbolIcon Checkmark24}" Content="Acknowledge" Appearance="Secondary"
                                           ToolTip="Acknowledge visible or selected alerts"
                                           Margin="0,0,6,4" Padding="10,6" FontSize="12">
                            <ui:DropDownButton.Flyout>
                                <ContextMenu>
                                    <MenuItem Header="Visible" Command="{Binding AcknowledgeVisibleCommand}">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Eye24" FontSize="14"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Selected" Command="{Binding AcknowledgeCommand}">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="CheckmarkSquare24" FontSize="14"/></MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </ui:DropDownButton.Flyout>
                        </ui:DropDownButton>
                        <ui:DropDownButton Icon="{ui:SymbolIcon CheckmarkCircle24}" Content="Resolve" Appearance="Primary"
                                           ToolTip="Resolve visible or selected alerts"
                                           Margin="0,0,12,4" Padding="10,6" FontSize="12">
                            <ui:DropDownButton.Flyout>
                                <ContextMenu>
                                    <MenuItem Header="Visible" Command="{Binding ResolveVisibleCommand}">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="Eye24" FontSize="14"/></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Selected" Command="{Binding ResolveCommand}">
                                        <MenuItem.Icon><ui:SymbolIcon Symbol="CheckmarkSquare24" FontSize="14"/></MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </ui:DropDownButton.Flyout>
                        </ui:DropDownButton>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock Text="Show " FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ComboBox SelectedValue="{Binding PageSize, Mode=TwoWay}"
                                      ItemsSource="{Binding PageSizeOptions}"
                                      Width="70" Margin="0,0,5,0"/>
                            <TextBlock Text="entries" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:Button Icon="{ui:SymbolIcon ArrowDownload24}" Content="Export" Appearance="Secondary" Command="{Binding ExportCommand}" Margin="8,0,0,0" Padding="10,6" FontSize="12"/>
                        </StackPanel>
                    </WrapPanel>
                </Grid>

                <DataGrid Grid.Row="1" ItemsSource="{Binding PagedAlerts}"
                          SelectedItem="{Binding SelectedAlert}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          ColumnHeaderHeight="36"
                          RowHeight="34"
                          MinHeight="350"
                          Margin="8,0,8,0">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="40">
                            <DataGridTemplateColumn.Header>
                                <CheckBox IsChecked="{Binding DataContext.IsAllSelected, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" SortMemberPath="Timestamp" Width="1.4*" HeaderStyle="{StaticResource SortableColumnHeaderStyle}"/>
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="0.9*" HeaderStyle="{StaticResource SortableColumnHeaderStyle}"/>
                        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="0.9*" HeaderStyle="{StaticResource SortableColumnHeaderStyle}"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="1*" HeaderStyle="{StaticResource SortableColumnHeaderStyle}"/>
                        <DataGridTextColumn Header="PC" Binding="{Binding PCName}" Width="1.3*" HeaderStyle="{StaticResource SortableColumnHeaderStyle}"/>
                        <DataGridTextColumn Header="Laboratory" Binding="{Binding RoomName}" Width="1*" HeaderStyle="{StaticResource SortableColumnHeaderStyle}"/>
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="2*" HeaderStyle="{StaticResource SortableColumnHeaderStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AlertCount}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="36" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="No alerts match current filters" Margin="0,8,0,0" FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Try adjusting your filters or check back later" Margin="0,4,0,0" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Pagination controls -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,12">
                    <ui:Button Command="{Binding PreviousPageCommand}"
                               Content="Previous"
                               Icon="{ui:SymbolIcon ChevronLeft24}"
                               Appearance="Primary"
                               Margin="0,0,10,0"/>

                    <TextBlock Text="{Binding PageInfo}" FontSize="13"
                               VerticalAlignment="Center" Margin="15,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>

                    <ui:Button Command="{Binding NextPageCommand}"
                               Content="Next"
                               Icon="{ui:SymbolIcon ChevronRight24}"
                               Appearance="Primary"
                               Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>
