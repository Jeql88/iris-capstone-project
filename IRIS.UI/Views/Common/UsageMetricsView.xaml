<UserControl x:Class="IRIS.UI.Views.Common.UsageMetricsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:IRIS.UI.ViewModels"
             xmlns:converters="clr-namespace:IRIS.UI.Converters">
    
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="25,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:SymbolIcon Symbol="DataUsage24" FontSize="32" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="Usage Metrics" FontSize="32" FontWeight="Bold" 
                           Foreground="{DynamicResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Date Range Filter -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="From:" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#1a1a1a"/>
                <DatePicker SelectedDate="{Binding StartDate}" Width="140"/>
                <TextBlock Text="To:" FontSize="14" VerticalAlignment="Center" Margin="15,0,8,0" Foreground="#1a1a1a"/>
                <DatePicker SelectedDate="{Binding EndDate}" Width="140"/>
                <ui:Button Icon="{ui:SymbolIcon Filter24}" 
                           Content="Apply Filter"
                           Command="{Binding ApplyFilterCommand}"
                           Appearance="Primary" Margin="15,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Summary Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Applications Card -->
            <ui:Card Grid.Column="0">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="55" Height="55" CornerRadius="10" 
                            Background="{DynamicResource IRISPrimaryBrush}" Margin="0,0,18,0">
                        <ui:SymbolIcon Symbol="Apps24" FontSize="26" Foreground="White" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Applications Used" FontSize="13" 
                                   Foreground="#666666"/>
                        <TextBlock Text="{Binding TotalApplications}" FontSize="32" FontWeight="Bold" 
                                   Foreground="{DynamicResource IRISPrimaryBrush}"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Total Websites Card -->
            <ui:Card Grid.Column="2">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="55" Height="55" CornerRadius="10" 
                            Background="{DynamicResource IRISSecondaryBrush}" Margin="0,0,18,0">
                        <ui:SymbolIcon Symbol="Globe24" FontSize="26" Foreground="White" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Websites Visited" FontSize="13" 
                                   Foreground="#666666"/>
                        <TextBlock Text="{Binding TotalWebsites}" FontSize="32" FontWeight="Bold" 
                                   Foreground="{DynamicResource IRISSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Total Hours Card -->
            <ui:Card Grid.Column="4">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="55" Height="55" CornerRadius="10" 
                            Background="{DynamicResource IRISAccentBrush}" Margin="0,0,18,0">
                        <ui:SymbolIcon Symbol="Timer24" FontSize="26" Foreground="White" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Total Usage Hours" FontSize="13" 
                                   Foreground="#666666"/>
                        <TextBlock Text="{Binding TotalHours, StringFormat={}{0:F1}h}" FontSize="32" FontWeight="Bold" 
                                   Foreground="{DynamicResource IRISAccentBrush}"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </Grid>

        <!-- Tab Content Area -->
        <ui:Card Grid.Row="2">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab Header -->
                <Grid Grid.Row="0" Margin="10,10,10,20">
                    <StackPanel Orientation="Horizontal">
                        <ui:Button x:Name="AppUsageTab" Content="Application Usage"
                                   Icon="{ui:SymbolIcon Apps24}"
                                   Appearance="Primary"
                                   Click="AppUsageTab_Click"
                                   Margin="0,0,10,0"/>
                        <ui:Button x:Name="WebUsageTab" Content="Website Usage"
                                   Icon="{ui:SymbolIcon Globe24}"
                                   Appearance="Secondary"
                                   Click="WebUsageTab_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Application Usage Tab -->
                <Grid Grid.Row="1" x:Name="ApplicationUsagePanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" Margin="10,0,10,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Apps24" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Application Usage Data" FontSize="16" FontWeight="Bold" 
                                       Foreground="{DynamicResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ui:TextBox PlaceholderText="Search applications..."
                                       Text="{Binding AppSearchText, UpdateSourceTrigger=PropertyChanged}"
                                       Width="220">
                                <ui:TextBox.Icon>
                                    <ui:SymbolIcon Symbol="Search24"/>
                                </ui:TextBox.Icon>
                            </ui:TextBox>
                            <ui:Button Icon="{ui:SymbolIcon ArrowDownload24}" 
                                       Content="Export"
                                       Command="{Binding ExportAppUsageCommand}"
                                       Appearance="Secondary" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Application Usage DataGrid -->
                    <ui:DataGrid Grid.Row="1" 
                                ItemsSource="{Binding FilteredApplicationUsage}"
                                AutoGenerateColumns="False"
                                IsReadOnly="True"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                SelectionMode="Single"
                                Margin="10,0">
                        <ui:DataGrid.Columns>
                            <DataGridTemplateColumn Header="Application" Width="*" SortMemberPath="ApplicationName">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="10,5">
                                            <Border Width="32" Height="32" CornerRadius="8" 
                                                    Background="{DynamicResource IRISPrimaryBrush}" Margin="0,0,10,0">
                                                <ui:SymbolIcon Symbol="Apps24" FontSize="16" Foreground="White"/>
                                            </Border>
                                            <TextBlock Text="{Binding ApplicationName}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#1a1a1a"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="PC Name" Binding="{Binding PCName}" Width="150"/>
                            <DataGridTextColumn Header="Room" Binding="{Binding RoomNumber}" Width="100"/>
                            <DataGridTextColumn Header="Duration" Binding="{Binding FormattedDuration}" Width="120"/>
                            <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime, StringFormat='{}{0:MM/dd/yyyy HH:mm}'}" Width="150"/>
                            <DataGridTextColumn Header="End Time" Binding="{Binding EndTime, StringFormat='{}{0:MM/dd/yyyy HH:mm}'}" Width="150"/>
                        </ui:DataGrid.Columns>
                    </ui:DataGrid>
                </Grid>

                <!-- Website Usage Tab -->
                <Grid Grid.Row="1" x:Name="WebsiteUsagePanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Grid.Row="0" Margin="10,0,10,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Globe24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Website Usage Data" FontSize="16" FontWeight="Bold" 
                                       Foreground="{DynamicResource IRISSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ui:TextBox PlaceholderText="Search websites..."
                                       Text="{Binding WebSearchText, UpdateSourceTrigger=PropertyChanged}"
                                       Width="220">
                                <ui:TextBox.Icon>
                                    <ui:SymbolIcon Symbol="Search24"/>
                                </ui:TextBox.Icon>
                            </ui:TextBox>
                            <ui:Button Icon="{ui:SymbolIcon ArrowDownload24}" 
                                       Content="Export"
                                       Command="{Binding ExportWebUsageCommand}"
                                       Appearance="Secondary" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Website Usage DataGrid -->
                    <ui:DataGrid Grid.Row="1" 
                                ItemsSource="{Binding FilteredWebsiteUsage}"
                                AutoGenerateColumns="False"
                                IsReadOnly="True"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                SelectionMode="Single"
                                Margin="10,0">
                        <ui:DataGrid.Columns>
                            <DataGridTemplateColumn Header="Website" Width="*" SortMemberPath="Url">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="10,5">
                                            <Border Width="32" Height="32" CornerRadius="8" 
                                                    Background="{DynamicResource IRISSecondaryBrush}" Margin="0,0,10,0">
                                                <ui:SymbolIcon Symbol="Globe24" FontSize="16" Foreground="White"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" 
                                                           TextTrimming="CharacterEllipsis" MaxWidth="300" Foreground="#1a1a1a"/>
                                                <TextBlock Text="{Binding Url}" FontSize="11" 
                                                           Foreground="#666666"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="PC Name" Binding="{Binding PCName}" Width="150"/>
                            <DataGridTextColumn Header="Room" Binding="{Binding RoomNumber}" Width="100"/>
                            <DataGridTextColumn Header="Duration" Binding="{Binding FormattedDuration}" Width="120"/>
                            <DataGridTextColumn Header="Visit Time" Binding="{Binding VisitTime, StringFormat='{}{0:MM/dd/yyyy HH:mm}'}" Width="150"/>
                        </ui:DataGrid.Columns>
                    </ui:DataGrid>
                </Grid>

                <!-- Loading Indicator -->
                <Grid Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}" Opacity="0.8"/>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:ProgressRing IsIndeterminate="True" Width="50" Height="50"/>
                        <TextBlock Text="Loading metrics data..." FontSize="14" Margin="0,15,0,0" Foreground="#1a1a1a"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>
