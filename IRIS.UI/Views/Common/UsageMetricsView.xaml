<UserControl x:Class="IRIS.UI.Views.Common.UsageMetricsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:IRIS.UI.Converters">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="25,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="DataUsage24" FontSize="32" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,12,0"/>
                <TextBlock Text="Usage Metrics" FontSize="32" FontWeight="Bold"
                           Foreground="{DynamicResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Tab Content Area -->
        <ui:Card Grid.Row="1">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="10,10,10,20">
                    <StackPanel Orientation="Horizontal">
                        <ui:Button x:Name="AppUsageTab" Content="Application Usage"
                                   Icon="{ui:SymbolIcon Apps24}"
                                   Appearance="Primary"
                                   Click="AppUsageTab_Click"
                                   Margin="0,0,10,0"/>
                        <ui:Button x:Name="WebUsageTab" Content="Website Usage"
                                   Icon="{ui:SymbolIcon Globe24}"
                                   Appearance="Secondary"
                                   Click="WebUsageTab_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Application Usage Tab -->
                <Grid Grid.Row="1" x:Name="ApplicationUsagePanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="10,0,10,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Apps24" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Application Usage Data" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource IRISPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Show " FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ComboBox ItemsSource="{Binding PageSizeOptions}"
                                      SelectedItem="{Binding PageSize}"
                                      Width="70" Margin="0,0,5,0"/>
                            <TextBlock Text="entries" FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:Button Icon="{ui:SymbolIcon ArrowDownload24}"
                                       Content="Export"
                                       Command="{Binding ExportAppUsageCommand}"
                                       Appearance="Secondary"/>
                        </StackPanel>
                    </Grid>

                    <ui:Card Grid.Row="1" Margin="10,0,10,15">
                        <StackPanel Margin="15">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <ui:SymbolIcon Symbol="Filter24" Foreground="{DynamicResource IRISPrimaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Search and Filters" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource IRISPrimaryBrush}"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                    <TextBlock Text="Search" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <ui:TextBox PlaceholderText="Search applications..."
                                                Text="{Binding AppSearchText, UpdateSourceTrigger=PropertyChanged}">
                                        <ui:TextBox.Icon>
                                            <ui:SymbolIcon Symbol="Search24"/>
                                        </ui:TextBox.Icon>
                                    </ui:TextBox>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                                    <TextBlock Text="Laboratory" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <ComboBox ItemsSource="{Binding AppLaboratoryOptions}"
                                              SelectedItem="{Binding SelectedAppLaboratory}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,15,0">
                                    <TextBlock Text="From" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <Grid>
                                        <DatePicker SelectedDate="{Binding StartDate}" DisplayDateEnd="{Binding EndDate}"/>
                                        <TextBlock Text="dd/mm/yyyy"
                                                   Margin="12,0,36,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StartDate}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Margin="0,0,0,0">
                                    <TextBlock Text="To" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <Grid>
                                        <DatePicker SelectedDate="{Binding EndDate}" DisplayDateStart="{Binding StartDate}"/>
                                        <TextBlock Text="dd/mm/yyyy"
                                                   Margin="12,0,36,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EndDate}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                                <ui:Button Content="Apply Filters"
                                           Command="{Binding ApplyAppFiltersCommand}"
                                           Appearance="Primary"
                                           Margin="0,0,8,0"/>
                                <ui:Button Content="Reset"
                                           Command="{Binding ResetAppFiltersCommand}"
                                           Appearance="Secondary"/>
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>

                    <Grid Grid.Row="2" Margin="10,0,10,0" MinHeight="280">
                        <ui:DataGrid ItemsSource="{Binding FilteredApplicationUsage}"
                                     AutoGenerateColumns="False"
                                     IsReadOnly="True"
                                     CanUserAddRows="False"
                                     CanUserDeleteRows="False"
                                     SelectionMode="Single">
                            <ui:DataGrid.Columns>
                                <DataGridTemplateColumn Header="Application" Width="*" SortMemberPath="ApplicationName">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="10,5">
                                                <Border Width="32" Height="32" CornerRadius="8"
                                                        Background="{DynamicResource IRISPrimaryBrush}" Margin="0,0,10,0">
                                                    <ui:SymbolIcon Symbol="Apps24" FontSize="16" Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="{Binding ApplicationName}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="PC Name" Binding="{Binding PCName}" Width="150"/>
                                <DataGridTextColumn Header="Laboratories" Binding="{Binding RoomNumber}" Width="100"/>
                                <DataGridTextColumn Header="Duration" Binding="{Binding FormattedDuration}" Width="120"/>
                                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="150"/>
                                <DataGridTextColumn Header="End Time" Binding="{Binding EndTime, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="150"/>
                            </ui:DataGrid.Columns>
                        </ui:DataGrid>

                        <Border VerticalAlignment="Top"
                                Margin="0,42,0,0"
                                Height="220"
                                Background="{DynamicResource LayerFillColorDefaultBrush}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilteredApplicationUsage.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="Apps24" FontSize="44" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12"/>
                                <TextBlock Text="No applications found" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Try adjusting the filters or date range" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <ui:Button Command="{Binding AppPreviousPageCommand}"
                                   Content="Previous"
                                   Icon="{ui:SymbolIcon ChevronLeft24}"
                                   Appearance="Primary"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding AppPageInfo}" FontSize="13"
                                   VerticalAlignment="Center" Margin="15,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ui:Button Command="{Binding AppNextPageCommand}"
                                   Content="Next"
                                   Icon="{ui:SymbolIcon ChevronRight24}"
                                   Appearance="Primary"
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Website Usage Tab -->
                <Grid Grid.Row="1" x:Name="WebsiteUsagePanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="10,0,10,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Globe24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="Website Usage Data" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource IRISSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Show " FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ComboBox ItemsSource="{Binding PageSizeOptions}"
                                      SelectedItem="{Binding PageSize}"
                                      Width="70" Margin="0,0,5,0"/>
                            <TextBlock Text="entries" FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <ui:Button Icon="{ui:SymbolIcon ArrowDownload24}"
                                       Content="Export"
                                       Command="{Binding ExportWebUsageCommand}"
                                       Appearance="Secondary"/>
                        </StackPanel>
                    </Grid>

                    <ui:Card Grid.Row="1" Margin="10,0,10,15">
                        <StackPanel Margin="15">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <ui:SymbolIcon Symbol="Filter24" Foreground="{DynamicResource IRISSecondaryBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="Search and Filters" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource IRISSecondaryBrush}"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                    <TextBlock Text="Search" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <ui:TextBox PlaceholderText="Search websites..."
                                                Text="{Binding WebSearchText, UpdateSourceTrigger=PropertyChanged}">
                                        <ui:TextBox.Icon>
                                            <ui:SymbolIcon Symbol="Search24"/>
                                        </ui:TextBox.Icon>
                                    </ui:TextBox>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Laboratory" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <ComboBox ItemsSource="{Binding WebLaboratoryOptions}"
                                              SelectedItem="{Binding SelectedWebLaboratory}"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                                <ui:Button Content="Apply Filters"
                                           Command="{Binding ApplyWebFiltersCommand}"
                                           Appearance="Primary"
                                           Margin="0,0,8,0"/>
                                <ui:Button Content="Reset"
                                           Command="{Binding ResetWebFiltersCommand}"
                                           Appearance="Secondary"/>
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>

                    <Grid Grid.Row="2" Margin="10,0,10,0" MinHeight="280">
                        <ui:DataGrid ItemsSource="{Binding FilteredWebsiteUsage}"
                                     AutoGenerateColumns="False"
                                     IsReadOnly="True"
                                     CanUserAddRows="False"
                                     CanUserDeleteRows="False"
                                     SelectionMode="Single">
                            <ui:DataGrid.Columns>
                                <DataGridTemplateColumn Header="Website" Width="*" SortMemberPath="Domain">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="10,5">
                                                <Border Width="32" Height="32" CornerRadius="8"
                                                        Background="{DynamicResource IRISSecondaryBrush}" Margin="0,0,10,0">
                                                    <ui:SymbolIcon Symbol="Globe24" FontSize="16" Foreground="White"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Domain}" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" MaxWidth="300" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Browser}" FontSize="11"
                                                               Foreground="#666666"
                                                               TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="PC Name" Binding="{Binding PCName}" Width="150"/>
                                <DataGridTextColumn Header="Laboratory" Binding="{Binding RoomNumber}" Width="100"/>
                                <DataGridTextColumn Header="Visits" Binding="{Binding VisitCount}" Width="120"/>
                            </ui:DataGrid.Columns>
                        </ui:DataGrid>

                        <Border VerticalAlignment="Top"
                                Margin="0,42,0,0"
                                Height="220"
                                Background="{DynamicResource LayerFillColorDefaultBrush}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilteredWebsiteUsage.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="Globe24" FontSize="44" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12"/>
                                <TextBlock Text="No websites found" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Try adjusting the filters or date range" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <ui:Button Command="{Binding WebPreviousPageCommand}"
                                   Content="Previous"
                                   Icon="{ui:SymbolIcon ChevronLeft24}"
                                   Appearance="Primary"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding WebPageInfo}" FontSize="13"
                                   VerticalAlignment="Center" Margin="15,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <ui:Button Command="{Binding WebNextPageCommand}"
                                   Content="Next"
                                   Icon="{ui:SymbolIcon ChevronRight24}"
                                   Appearance="Primary"
                                   Margin="10,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Loading Indicator -->
                <Grid Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}" Opacity="0.8"/>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:ProgressRing IsIndeterminate="True" Width="50" Height="50"/>
                        <TextBlock Text="Loading metrics data..." FontSize="14" Margin="0,15,0,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </ui:Card>
    </Grid>
</UserControl>
