<Application x:Class="IRIS.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:IRIS.UI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- IRIS Red Theme Colors -->
            <Color x:Key="IRISPrimary">#8B0000</Color>
            <Color x:Key="IRISSecondary">#DC143C</Color>
            <Color x:Key="IRISAccent">#FF4141</Color>
            <Color x:Key="IRISDark">#620F1E</Color>
            <Color x:Key="IRISLight">#FFF5F5</Color>
            
            <!-- Brush Resources -->
            <SolidColorBrush x:Key="IRISPrimaryBrush" Color="{StaticResource IRISPrimary}" />
            <SolidColorBrush x:Key="IRISSecondaryBrush" Color="{StaticResource IRISSecondary}" />
            <SolidColorBrush x:Key="IRISAccentBrush" Color="{StaticResource IRISAccent}" />
            <SolidColorBrush x:Key="IRISDarkBrush" Color="{StaticResource IRISDark}" />
            <SolidColorBrush x:Key="IRISLightBrush" Color="{StaticResource IRISLight}" />
            
            <!-- Override WPF-UI accent colors with red theme -->
            <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="#DC143C" />
            <SolidColorBrush x:Key="SystemAccentColorSecondaryBrush" Color="#8B0000" />
            <SolidColorBrush x:Key="SystemAccentColorTertiaryBrush" Color="#FF4141" />
            
            <!-- Status Colors -->
            <SolidColorBrush x:Key="OnlineStatusBrush" Color="#10B981" />
            <SolidColorBrush x:Key="OfflineStatusBrush" Color="#EF4444" />
            <SolidColorBrush x:Key="WarningStatusBrush" Color="#F59E0B" />
            
            <!-- Global TextBlock Style for visibility on light backgrounds -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="#1a1a1a"/>
            </Style>
            
            <!-- ComboBox ItemTemplate TextBlock fix -->
            <Style x:Key="ComboBoxItemText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#1a1a1a"/>
            </Style>
            
            <!-- Fix TextBox/PasswordBox placeholder and text visibility -->
            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="Foreground" Value="#1a1a1a"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="CaretBrush" Value="#1a1a1a"/>
            </Style>
            
            <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
                <Setter Property="Foreground" Value="#1a1a1a"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                <Setter Property="CaretBrush" Value="#1a1a1a"/>
            </Style>
            
            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="Foreground" Value="#1a1a1a"/>
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
            </Style>
            
            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                <Setter Property="Foreground" Value="#1a1a1a"/>
            </Style>
            
            <!-- ContentPresenter inside ComboBox -->
            <Style TargetType="ContentPresenter">
                <Style.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#1a1a1a"/>
                    </Style>
                </Style.Resources>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
