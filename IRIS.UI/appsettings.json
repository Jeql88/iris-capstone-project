{
  "ConnectionStrings": {
    "IRISDatabase": "Host=localhost;Port=5432;Database=iris_db;Username=postgres;Password=password"
  },
  "AgentSettings": {
    "ScreenStreamPort": 5057,
    "ScreenStreamToken": "change-me-iris-stream-token",
    "FileApiPort": 5065,
    "FileApiToken": "change-me-iris-file-token"
  },

  "PowerCommandServer": {
    "Port": 5091,
    "EnsureFirewallRuleOnStartup": true,
    "FirewallRuleName": "IRIS UI Power Command TCP 5091"
  },
  "WallpaperServer": {
    "Port": 5092,
    "RoutePrefix": "/api/wallpapers",
    "PublicBaseUrl": "http://172.20.10.9:5092",
    "ApiToken": "change-me-iris-wallpaper-token",
    "RootPath": "%PROGRAMDATA%\\IRIS\\Wallpapers",
    "EnsureFirewallRuleOnStartup": true,
    "FirewallRuleName": "IRIS UI Wallpaper HTTP 5092",
    "EnsureUrlAclOnStartup": true,
    "UrlAclUser": "Everyone"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
